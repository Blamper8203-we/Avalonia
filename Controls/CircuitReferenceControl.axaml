<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:DINBoard.Models"
             x:Class="DINBoard.Controls.CircuitReferenceControl"
             x:DataType="models:CircuitReference">
    
    <UserControl.Styles>
        <Style Selector="Border.reference-circle">
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Border.reference-circle:pointerover">
            <Setter Property="Opacity" Value="0.8"/>
        </Style>
    </UserControl.Styles>
    
    <!-- Odsyłacz: Kółko z numerem -->
    <Grid Width="60" Height="60" ClipToBounds="False">
        <!-- Kółko z numerem odsyłacza -->
        <Border Name="ReferenceCircle"
                Classes="reference-circle"
                Classes.highlighted="{Binding IsHighlighted}"
                Width="24" Height="24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                CornerRadius="12"
                BorderThickness="2"
                Background="{DynamicResource PanelBackground}">
            
            <Border.Styles>
                <Style Selector="Border.reference-circle.highlighted">
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentGreen}"/>
                    <Setter Property="BoxShadow" Value="{DynamicResource ReferenceHighlightShadow}"/>
                </Style>
                <Style Selector="Border.reference-circle.highlighted">
                    <Style.Animations>
                        <Animation Duration="0:0:0.5" IterationCount="6" PlaybackDirection="Alternate">
                            <KeyFrame Cue="0%">
                                <Setter Property="Opacity" Value="1"/>
                            </KeyFrame>
                            <KeyFrame Cue="100%">
                                <Setter Property="Opacity" Value="0.6"/>
                            </KeyFrame>
                        </Animation>
                    </Style.Animations>
                </Style>
            </Border.Styles>
            
            <TextBlock Text="{Binding Label}"
                       FontSize="9"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextMain}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
            
            <ToolTip.Tip>
                <StackPanel Spacing="4">
                    <TextBlock Text="{Binding Label}" FontWeight="Bold" FontSize="12"/>
                    <TextBlock Text="{Binding CircuitName}" FontSize="12"/>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="Faza:" FontSize="10" Foreground="{DynamicResource TextSecondary}"/>
                        <TextBlock Text="{Binding Phase}" FontSize="10" Foreground="{DynamicResource TextSecondary}"/>
                    </StackPanel>
                    <TextBlock Text="Kliknij aby przejść do schematu" 
                               FontSize="9" 
                               Foreground="{DynamicResource TextTertiary}"
                               FontStyle="Italic"/>
                </StackPanel>
            </ToolTip.Tip>
        </Border>

        <!-- Phase Label (User Request: "oznaczenie l1,l2,l3") -->
        <TextBlock Text="{Binding Phase}"
                   FontSize="8"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextTertiary}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Top"
                   Margin="0,-14,0,0"
                   IsHitTestVisible="False"/>
    </Grid>
</UserControl>
