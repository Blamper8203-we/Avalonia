<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:mi="using:Material.Icons.Avalonia"
        xmlns:models="using:DINBoard.Models"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="DINBoard.Dialogs.ExcelImportDialog"
        x:CompileBindings="False"
        Title="Importuj obwody z pliku Excel"
        Width="850" Height="550"
        WindowStartupLocation="CenterOwner"
        ExtendClientAreaToDecorationsHint="True"
        Background="{DynamicResource AppBackground}">

    <Window.Styles>
        <Style Selector="DataGridColumnHeader">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="{DynamicResource PanelBackgroundAlt}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto, *, Auto">
        <!-- HEADER -->
        <Border Grid.Row="0" Background="{DynamicResource PanelBackgroundAlt}" BorderBrush="{DynamicResource PanelBorder}" BorderThickness="0,0,0,1" Padding="20,16" IsHitTestVisible="False">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Border Background="{DynamicResource AccentBlue}" CornerRadius="4" Padding="6">
                    <mi:MaterialIcon Kind="MicrosoftExcel" Width="20" Height="20" Foreground="White"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Import z pliku Excel" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource TextMain}"/>
                    <TextBlock Text="Wczytaj listę obwodów ze struktur tabelarycznych (.xlsx, .csv)" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- CONTENT -->
        <Grid Grid.Row="1" Margin="20" RowDefinitions="Auto,*">
            
            <StackPanel Grid.Row="0" Spacing="12" Margin="0,0,0,16">
                <!-- File Selection -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                    <TextBox x:Name="FilePathTextBox" IsReadOnly="True" Watermark="Wybierz plik .xlsx..." VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Margin="8,0,0,0" x:Name="BtnBrowse" Click="BtnBrowse_Click" ToolTip.Tip="Wybierz plik">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <mi:MaterialIcon Kind="FolderOpenOutline" Width="16" Height="16"/>
                            <TextBlock Text="Przeglądaj"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Options -->
                <CheckBox x:Name="ChbHasHeaders" IsChecked="True" Content="Pierwszy wiersz zawiera nagłówki" Checked="ChbHasHeaders_Changed" Unchecked="ChbHasHeaders_Changed"/>
                
                <Border Background="{DynamicResource PanelBackgroundAlt}" CornerRadius="4" Padding="12" BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1">
                    <TextBlock Text="Oczekiwane ułożenie kolumn: A - Nazwa | B - Moc (W) | C - Zabezpieczenie | D - Faza | E - Lokalizacja" 
                               FontSize="11" Foreground="{DynamicResource TextSecondary}" FontStyle="Italic"/>
                </Border>
            </StackPanel>

            <!-- DataGrid Preview -->
            <Border Grid.Row="1" Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1" CornerRadius="4">
                <DataGrid x:Name="PreviewGrid" 
                          AutoGenerateColumns="False" 
                          IsReadOnly="True"
                          GridLinesVisibility="All"
                          BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Nr" Binding="{Binding RowIndex}" Width="50" />
                        <DataGridTextColumn Header="Nazwa obwodu" Binding="{Binding CircuitName}" Width="*" />
                        <DataGridTextColumn Header="Moc [W]" Binding="{Binding PowerW}" Width="80" />
                        <DataGridTextColumn Header="Zabezpieczenie" Binding="{Binding Protection}" Width="110" />
                        <DataGridTextColumn Header="Faza" Binding="{Binding Phase}" Width="70" />
                        <DataGridTextColumn Header="Lokalizacja" Binding="{Binding Location}" Width="150" />
                        <DataGridTextColumn Header="Status" Binding="{Binding ValidationError}" Width="150">
                            <!-- Could add red text style if ValidationError is not empty, but standard text is fine for MVP -->
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- FOOTER -->
        <Border Grid.Row="2" Background="{DynamicResource PanelBackgroundAlt}" BorderBrush="{DynamicResource PanelBorder}" BorderThickness="0,1,0,0" Padding="20,12">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock x:Name="StatusTextBlock" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                    <Button Click="BtnCancel_Click" Content="Anuluj" Classes="secondary" Width="100" HorizontalContentAlignment="Center"/>
                    <Button x:Name="BtnImport" Click="BtnImport_Click" Content="Importuj zaznaczone" Background="{DynamicResource AccentBlue}" Foreground="White" Width="160" FontWeight="Bold" HorizontalContentAlignment="Center" IsEnabled="False"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
