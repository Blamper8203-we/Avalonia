<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:mi="using:Material.Icons.Avalonia"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="600"
        Width="500" MinHeight="400" MaxHeight="800"
        SizeToContent="Height"
        x:Class="DINBoard.Dialogs.GroupModulesDialog"
        Title="{DynamicResource DialogGroupModulesTitle}"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource PanelBackground}">

    <Grid RowDefinitions="Auto, *, Auto" Margin="20">
        
        <!-- Header -->
        <StackPanel Spacing="8">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Border Background="{DynamicResource AccentOrange}" CornerRadius="4" Width="32" Height="32">
                    <mi:MaterialIcon Kind="FolderMultiple" Width="20" Height="20" 
                                     Foreground="White" 
                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock x:Name="GroupNameText" 
                           Text="Grupa - 1" 
                           FontSize="20" 
                           FontWeight="Bold" 
                           Foreground="{DynamicResource TextMain}"
                           VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Text="{DynamicResource TextGroupModulesDesc}" 
                       FontSize="12" 
                       Foreground="{DynamicResource TextSecondary}"
                       Margin="0,0,0,12"/>
        </StackPanel>

        <!-- Modules List -->
        <ScrollViewer Grid.Row="1" Margin="0,8">
            <StackPanel x:Name="ModulesPanel" Spacing="12">
                <!-- Modules will be added dynamically -->
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,16,0,0">
            <Button x:Name="BtnCancel" Content="{DynamicResource DialogCancel}" Click="BtnCancel_Click"
                    Background="{DynamicResource PanelBackgroundAlt}" Foreground="{DynamicResource TextMain}" Padding="16,8"/>
            <Button x:Name="BtnSave" Content="{DynamicResource DialogSaveChanges}" Click="BtnSave_Click"
                    Background="{DynamicResource AccentOrange}" Foreground="White" Padding="16,8" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
