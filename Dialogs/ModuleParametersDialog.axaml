<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:mi="using:Material.Icons.Avalonia"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="300"
        Width="360" Height="360"
        x:Class="DINBoard.Dialogs.ModuleParametersDialog"
        Title="{DynamicResource DialogModuleParametersTitle}"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{DynamicResource PanelBackground}">

    <Grid RowDefinitions="Auto, *, Auto" Margin="16">
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
            <mi:MaterialIcon Kind="TuneVariant" Width="18" Height="18" Foreground="{DynamicResource AccentBlue}"/>
            <TextBlock Text="{DynamicResource LabelModuleParameters}" FontSize="14" FontWeight="Medium" Foreground="{DynamicResource TextMain}"/>
        </StackPanel>

        <!-- Dynamic parameters list -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Name="ParametersPanel" Spacing="6"/>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
            <Button Name="BtnCancel" Content="{DynamicResource DialogCancel}" Click="BtnCancel_Click" FontSize="11"/>
            <Button Name="BtnSave" Classes="accent" Click="BtnSave_Click" FontSize="11">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <mi:MaterialIcon Kind="ContentSave" Width="12" Height="12"/>
                    <TextBlock Text="{DynamicResource DialogSave}"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</Window>
