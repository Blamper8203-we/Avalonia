<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:DINBoard.Models"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="600"
        x:Class="DINBoard.Dialogs.ProjectMetadataDialog"
        Title="{DynamicResource DialogProjectMetadataTitle}"
        Width="500" Height="650"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{DynamicResource AppBackground}">

    <Border Padding="20" Background="{DynamicResource PanelBackground}">
        <Grid RowDefinitions="Auto,*,Auto">
            
            <!-- Header -->
            <TextBlock Grid.Row="0" Text="{DynamicResource HeaderProjectMetadata}" 
                       FontSize="18" FontWeight="SemiBold" 
                       Foreground="{DynamicResource TextMain}" Margin="0,0,0,20"/>
            
            <!-- Form Grid -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
                <StackPanel Spacing="20">
                    
                    <StackPanel.Styles>
                        <Style Selector="TextBlock.label">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                            <Setter Property="Margin" Value="0,0,10,15"/>
                        </Style>
                        <Style Selector="TextBox">
                            <Setter Property="Margin" Value="0,0,0,15"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                        <Style Selector="TextBlock.section-header">
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Foreground" Value="{DynamicResource AccentBlue}"/>
                            <Setter Property="Margin" Value="0,0,0,10"/>
                        </Style>
                        <Style Selector="Border.section-border">
                            <Setter Property="Background" Value="#0AFFFFFF"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorder}"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="CornerRadius" Value="6"/>
                            <Setter Property="Padding" Value="15,15,15,0"/>
                        </Style>
                    </StackPanel.Styles>

                    <!-- SEKCJA: DANE PROJEKTU -->
                    <StackPanel>
                        <TextBlock Text="{DynamicResource SectionProjectData}" Classes="section-header"/>
                        <Border Classes="section-border">
                            <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto,Auto">
                                <!-- Row 0: Nazwa obiektu/projektu -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource LabelProjectName}" Classes="label"/>
                                <TextBox x:Name="ProjectNameTextBox" Grid.Row="0" Grid.Column="1" Watermark="{DynamicResource WatermarkProjectName}"/>

                                <!-- Row 1: Adres -->
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource LabelProjectAddress}" Classes="label"/>
                                <TextBox x:Name="AddressTextBox" Grid.Row="1" Grid.Column="1" Watermark="{DynamicResource WatermarkProjectAddress}"/>

                                <!-- Row 2: Inwestor -->
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource LabelProjectInvestor}" Classes="label"/>
                                <TextBox x:Name="InvestorTextBox" Grid.Row="2" Grid.Column="1" Watermark="{DynamicResource WatermarkProjectInvestor}"/>

                                <!-- Row 3: Wykonawca -->
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="{DynamicResource LabelProjectContractor}" Classes="label"/>
                                <TextBox x:Name="ContractorTextBox" Grid.Row="3" Grid.Column="1" Watermark="{DynamicResource WatermarkProjectContractor}"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- SEKCJA: DANE DOKUMENTU -->
                    <StackPanel>
                        <TextBlock Text="{DynamicResource SectionDocumentData}" Classes="section-header"/>
                        <Border Classes="section-border">
                            <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                                <!-- Row 0: Nr rysunku -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource LabelDocNumber}" Classes="label"/>
                                <TextBox x:Name="ProjectNumberTextBox" Grid.Row="0" Grid.Column="1" Watermark="{DynamicResource WatermarkDocNumber}"/>

                                <!-- Row 1: Imię i nazwisko autora -->
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource LabelDocAuthor}" Classes="label"/>
                                <TextBox x:Name="AuthorTextBox" Grid.Row="1" Grid.Column="1" Watermark="{DynamicResource WatermarkDocAuthor}"/>

                                <!-- Row 2: Numer uprawnień -->
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource LabelDocDesignerId}" Classes="label"/>
                                <TextBox x:Name="DesignerIdTextBox" Grid.Row="2" Grid.Column="1" Watermark="{DynamicResource WatermarkDocDesignerId}"/>

                                <!-- Row 3: Rewizja -->
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="{DynamicResource LabelDocRevision}" Classes="label"/>
                                <TextBox x:Name="RevisionTextBox" Grid.Row="3" Grid.Column="1" Watermark="{DynamicResource WatermarkDocRevision}"/>

                                <!-- Row 4: Notatki -->
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="{DynamicResource LabelDocNotes}" Classes="label" VerticalAlignment="Top" Margin="0,5,10,0"/>
                                <TextBox x:Name="NotesTextBox" Grid.Row="4" Grid.Column="1" 
                                         AcceptsReturn="True" TextWrapping="Wrap" Height="80" 
                                         Watermark="{DynamicResource WatermarkDocNotes}"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
            
            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,20,0,0">
                <Button Content="{DynamicResource DialogCancel}" Width="100" HorizontalContentAlignment="Center" Click="OnCancelClick"/>
                <Button Content="{DynamicResource DialogSave}" Width="100" HorizontalContentAlignment="Center" Classes="accent" Click="OnSaveClick"/>
            </StackPanel>
            
        </Grid>
    </Border>
</Window>
