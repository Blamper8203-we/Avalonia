<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:DINBoard.ViewModels"
        xmlns:models="using:DINBoard.Models"
        xmlns:views="using:DINBoard.Views"
        xmlns:controls="using:DINBoard.Controls"
        xmlns:converters="using:DINBoard.Converters"
        xmlns:mi="using:Material.Icons.Avalonia"
        xmlns:services="using:DINBoard.Services"
        x:Class="DINBoard.MainWindow"
        x:Name="RootWindow"
        x:DataType="vm:MainViewModel"
        mc:Ignorable="d" d:DesignWidth="1400" d:DesignHeight="800"
        Title="DINBoard"
        WindowState="Maximized"
        Width="1400" Height="900"
        MinWidth="1024" MinHeight="768"
        Background="{DynamicResource AppBackground}">
    
    <Window.Resources>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
        <converters:BoolToZIndexConverter x:Key="BoolToZIndexConverter" TrueValue="5" FalseValue="10"/>
    </Window.Resources>

    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+N" Command="{Binding Workspace.CreateProjectCommand}"/>
        <KeyBinding Gesture="Ctrl+O" Command="{Binding Workspace.LoadCommand}"/>
        <KeyBinding Gesture="Ctrl+S" Command="{Binding Workspace.SaveCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+S" Command="{Binding Workspace.SaveAsCommand}"/>
        <KeyBinding Gesture="Ctrl+Z" Command="{Binding UndoCommand}"/>
        <KeyBinding Gesture="Ctrl+Y" Command="{Binding RedoCommand}"/>
        <KeyBinding Gesture="Ctrl+D" Command="{Binding ModuleManager.DuplicateSelectedCommand}"/>
        <KeyBinding Gesture="Delete" Command="{Binding ModuleManager.DeleteSelectedCommand}"/>
        <KeyBinding Gesture="Ctrl+P" Command="{Binding Exporter.ExportPdfCommand}"/>
    </Window.KeyBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- TOOLBAR -->
        <Border Grid.Row="0" Background="{DynamicResource ToolbarBackground}" Padding="6,3" 
                BorderBrush="{DynamicResource PanelBorder}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: File Operations -->
                <StackPanel Orientation="Horizontal" Spacing="2">
                    
                    <!-- MENU PLIK -->
                    <Button Classes="toolbar-btn" Content="{DynamicResource MenuFile}" VerticalAlignment="Center">
                        <Button.Flyout>
                            <Flyout Placement="BottomEdgeAlignedLeft" ShowMode="Standard">
                                <Border Background="{DynamicResource MenuBackground}" BorderBrush="{DynamicResource MenuBorder}" BorderThickness="1" CornerRadius="6" Padding="3" Width="220">
                                    <StackPanel Spacing="1">
                                        <!-- PROJEKT -->
                                        <TextBlock Text="{DynamicResource MenuProject}" Foreground="{DynamicResource TextTertiary}" FontSize="9" FontWeight="Bold" Margin="8,4,8,2"/>
                                        
                                        <!-- Nowy -->
                                        <Button Command="{Binding Workspace.CreateProjectCommand}" Background="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="24"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <mi:MaterialIcon Kind="FileDocumentOutline" Width="16" Height="16" Foreground="{DynamicResource TextSecondary}"/>
                                                <TextBlock Grid.Column="1" Text="{DynamicResource MenuNewProject}" Margin="12,0,0,0" Foreground="{DynamicResource TextMain}" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="2" Text="Ctrl+N" Foreground="{DynamicResource TextTertiary}" FontSize="10" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Button>

                                        <!-- Otwórz -->
                                        <Button Command="{Binding Workspace.LoadCommand}" Background="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="24"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <mi:MaterialIcon Kind="FolderOpen" Width="16" Height="16" Foreground="{DynamicResource TextSecondary}"/>
                                                <TextBlock Grid.Column="1" Text="{DynamicResource MenuOpen}" Margin="12,0,0,0" Foreground="{DynamicResource TextMain}" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="2" Text="Ctrl+O" Foreground="{DynamicResource TextTertiary}" FontSize="10" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Button>

                                        <!-- Zapisz -->
                                        <Button Command="{Binding Workspace.SaveCommand}" Background="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="24"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <mi:MaterialIcon Kind="ContentSave" Width="16" Height="16" Foreground="{DynamicResource TextSecondary}"/>
                                                <TextBlock Grid.Column="1" Text="{DynamicResource MenuSave}" Margin="12,0,0,0" Foreground="{DynamicResource TextMain}" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="2" Text="Ctrl+S" Foreground="{DynamicResource TextTertiary}" FontSize="10" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Button>

                                        <!-- Import z Excela -->
                                        <Button Command="{Binding Workspace.ImportFromExcelCommand}" x:CompileBindings="False" Background="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="24"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <mi:MaterialIcon Kind="FileExcelBox" Width="16" Height="16" Foreground="{DynamicResource AccentGreen}"/>
                                                <TextBlock Grid.Column="1" Text="Importuj obwody z Excela..." Margin="12,0,0,0" Foreground="{DynamicResource TextMain}" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Button>

                                        <!-- Zapisz jako -->
                                        <Button Command="{Binding Workspace.SaveAsCommand}" Background="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="24"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <mi:MaterialIcon Kind="ContentSaveEdit" Width="16" Height="16" Foreground="{DynamicResource TextSecondary}"/>
                                                <TextBlock Grid.Column="1" Text="{DynamicResource MenuSaveAs}" Margin="12,0,0,0" Foreground="{DynamicResource TextMain}" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Button>
                                        
                                        <Rectangle Height="1" Fill="{DynamicResource MenuBorder}" Margin="0,4"/>

                                        <!-- EKSPORT -->
                                        <TextBlock Text="{DynamicResource MenuExport}" Foreground="{DynamicResource TextTertiary}" FontSize="10" FontWeight="Bold" Margin="12,4"/>
                                        
                                        <!-- Drukuj -->
                                        <Button Command="{Binding Workspace.PrintCommand}" Background="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="24"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <mi:MaterialIcon Kind="Printer" Width="16" Height="16" Foreground="{DynamicResource TextSecondary}"/>
                                                <TextBlock Grid.Column="1" Text="{DynamicResource MenuPrint}" Margin="12,0,0,0" Foreground="{DynamicResource TextMain}" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="2" Text="Ctrl+P" Foreground="{DynamicResource TextTertiary}" FontSize="10" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Button>

                                        <!-- Eksport PDF -->
                                        <Button Command="{Binding Exporter.ExportPdfCommand}" Background="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="8">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <TextBlock Text="📄" FontSize="16"/>
                                                <TextBlock Text="{DynamicResource MenuExportPdf}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>

                                        <!-- Eksport PNG (Czysty) -->
                                        <Button Command="{Binding Exporter.ExportPngCleanCommand}" Background="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="8">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <TextBlock Text="🖼" FontSize="16"/>
                                                <TextBlock Text="{DynamicResource MenuExportPngClean}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>

                                        <!-- Eksport PNG (Z Oznaczeniami) -->
                                        <Button Command="{Binding Exporter.ExportPngAnnotatedCommand}" Background="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="8">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <TextBlock Text="🖍" FontSize="16"/>
                                                <TextBlock Text="{DynamicResource MenuExportPngAnnotated}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>

                                        <!-- Eksport BOM (CSV) -->
                                        <Button Command="{Binding Exporter.ExportBomCommand}" Background="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="8">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <TextBlock Text="📋" FontSize="16"/>
                                                <TextBlock Text="{DynamicResource MenuExportBom}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>

                                        <Rectangle Height="1" Fill="{DynamicResource MenuBorder}" Margin="0,4"/>
                                        
                                        <!-- Wyjdź -->
                                        <Button Command="{Binding Workspace.ExitCommand}" Background="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="24"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <mi:MaterialIcon Kind="ExitToApp" Width="16" Height="16" Foreground="{DynamicResource AccentRed}"/>
                                                <TextBlock Grid.Column="1" Text="{DynamicResource MenuExit}" Margin="12,0,0,0" Foreground="{DynamicResource AccentRed}" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Button>

                                    </StackPanel>
                                </Border>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                    
                    <!-- MENU WIDOK -->
                    <Button Classes="toolbar-btn" Content="{DynamicResource MenuView}" VerticalAlignment="Center">
                        <Button.Flyout>
                            <Flyout Placement="BottomEdgeAlignedLeft" ShowMode="Standard">
                                <Border Background="{DynamicResource MenuBackground}" BorderBrush="{DynamicResource MenuBorder}" BorderThickness="1" CornerRadius="6" Padding="3" Width="220">
                                    <StackPanel Spacing="1">
                                        <TextBlock Text="{DynamicResource MenuDisplayOptions}" Foreground="{DynamicResource TextTertiary}" FontSize="9" FontWeight="Bold" Margin="8,4,8,2"/>
                                        
                                        <!-- Toggle prawy panel -->
                                        <Button Command="{Binding ToggleRightPanelCommand}" Background="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="24"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <mi:MaterialIcon Kind="DockRight" Width="16" Height="16" Foreground="{DynamicResource TextSecondary}"/>
                                                <TextBlock Grid.Column="1" Text="{DynamicResource MenuRightPanel}" Margin="12,0,0,0" Foreground="{DynamicResource TextMain}" VerticalAlignment="Center"/>
                                                <mi:MaterialIcon Grid.Column="2" Kind="Check" Width="14" Height="14" 
                                                                 Foreground="{DynamicResource AccentGreen}"
                                                                 IsVisible="{Binding IsRightPanelVisible}"/>
                                            </Grid>
                                        </Button>

                                        <Rectangle Height="1" Fill="{DynamicResource MenuBorder}" Margin="0,4"/>
                                        
                                        <TextBlock Text="{DynamicResource MenuSheets}" Foreground="{DynamicResource TextTertiary}" FontSize="9" FontWeight="Bold" Margin="8,4,8,2"/>
                                        
                                        <!-- Sheet 1: Szyna DIN -->
                                        <Button Command="{Binding Schematic.SwitchToSheet1Command}" Background="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="24"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <mi:MaterialIcon Kind="ViewModule" Width="16" Height="16" Foreground="{DynamicResource TextSecondary}"/>
                                                <TextBlock Grid.Column="1" Text="{DynamicResource MenuSheet1}" Margin="12,0,0,0" Foreground="{DynamicResource TextMain}" VerticalAlignment="Center"/>
                                                <mi:MaterialIcon Grid.Column="2" Kind="Check" Width="14" Height="14" 
                                                                 Foreground="{DynamicResource AccentGreen}"
                                                                 IsVisible="{Binding Schematic.IsSheet1Active}"/>
                                            </Grid>
                                        </Button>
                                        
                                        <!-- Sheet 2: Schemat jednokreskowy -->
                                        <Button Command="{Binding Schematic.SwitchToSheet2Command}" Background="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="24"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <mi:MaterialIcon Kind="FileTreeOutline" Width="16" Height="16" Foreground="{DynamicResource TextSecondary}"/>
                                                <TextBlock Grid.Column="1" Text="{DynamicResource MenuSheet2}" Margin="12,0,0,0" Foreground="{DynamicResource TextMain}" VerticalAlignment="Center"/>
                                                <mi:MaterialIcon Grid.Column="2" Kind="Check" Width="14" Height="14" 
                                                                 Foreground="{DynamicResource AccentGreen}"
                                                                 IsVisible="{Binding Schematic.IsSheet2Active}"/>
                                            </Grid>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                    <Border Width="1" Background="{DynamicResource PanelBorder}" Margin="4,2" Opacity="0.4"/>

                    <Button Classes="toolbar-btn" Command="{Binding UndoCommand}" ToolTip.Tip="{DynamicResource TooltipUndo}">
                        <mi:MaterialIcon Kind="Undo" Width="14" Height="14"/>
                    </Button>
                    <Button Classes="toolbar-btn" Command="{Binding RedoCommand}" ToolTip.Tip="{DynamicResource TooltipRedo}">
                        <mi:MaterialIcon Kind="Redo" Width="14" Height="14"/>
                    </Button>

                    <Border Width="1" Background="{DynamicResource PanelBorder}" Margin="4,2" Opacity="0.4"/>

                    <Button Classes="toolbar-btn" Command="{Binding ModuleManager.DeleteSelectedCommand}" ToolTip.Tip="{DynamicResource TooltipDeleteSelected}">
                        <mi:MaterialIcon Kind="TrashCanOutline" Width="14" Height="14"/>
                    </Button>

                    <Border Width="1" Background="{DynamicResource PanelBorder}" Margin="4,2" Opacity="0.4"/>

                    <Button Classes="toolbar-btn" x:Name="BtnDinRail" Click="BtnDinRail_Click" ToolTip.Tip="{DynamicResource ToolDinRail}">
                        <mi:MaterialIcon Kind="ViewModule" Width="14" Height="14"/>
                    </Button>
                    <Button Classes="toolbar-btn"
                            Command="{Binding GenerateBusbarCommand}"
                            ToolTip.Tip="{DynamicResource ToolBusbar}">
                        <mi:MaterialIcon Kind="PowerPlug" Width="14" Height="14"/>
                    </Button>
                    <Button Classes="toolbar-btn" x:Name="BtnImportModules" Click="BtnImportModules_Click" ToolTip.Tip="{DynamicResource ToolImportSvg}">
                        <mi:MaterialIcon Kind="FileImport" Width="14" Height="14"/>
                    </Button>

                    <Border Width="1" Background="{DynamicResource PanelBorder}" Margin="4,2" Opacity="0.4"/>

                    <Button Classes="toolbar-btn" x:Name="BtnZoomIn" Click="BtnZoomIn_Click" ToolTip.Tip="{DynamicResource TooltipZoomIn}">
                        <mi:MaterialIcon Kind="MagnifyPlus" Width="14" Height="14"/>
                    </Button>
                    <Button Classes="toolbar-btn" x:Name="BtnZoomOut" Click="BtnZoomOut_Click" ToolTip.Tip="{DynamicResource TooltipZoomOut}">
                        <mi:MaterialIcon Kind="MagnifyMinus" Width="14" Height="14"/>
                    </Button>
                    <Button Classes="toolbar-btn" x:Name="BtnZoomFit" Click="BtnZoomFit_Click" ToolTip.Tip="{DynamicResource TooltipZoomFit}">
                        <mi:MaterialIcon Kind="Target" Width="14" Height="14"/>
                    </Button>

                    </StackPanel>
                
                <!-- Right: Zoom & Settings -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="2">
                    <Border Width="1" Background="{DynamicResource PanelBorder}" Margin="4,2" Opacity="0.4"/>

                    <Button Classes="toolbar-btn" ToolTip.Tip="{DynamicResource ToolSettings}">
                        <mi:MaterialIcon Kind="Cog" Width="14" Height="14"/>
                        <Button.Flyout>
                            <Flyout Placement="BottomEdgeAlignedRight" ShowMode="Standard">
                                <Border Background="{DynamicResource PanelBackground}" 
                                        BorderBrush="{DynamicResource PanelBorder}" 
                                        BorderThickness="1" CornerRadius="6" Padding="0" Width="260" Height="220">
                                    <TabControl Margin="0">
                                        <!-- Zakładka Motywy -->
                                        <TabItem Header="{DynamicResource SettingsTheme}" FontSize="11">
                                            <StackPanel Spacing="10" Margin="10">
                                                <TextBlock Text="{DynamicResource SettingsSelectTheme}" FontSize="11" Classes="secondary"/>
                                                
                                                <ScrollViewer>
                                                    <ListBox ItemsSource="{Binding ProjectTheme.AvailableThemes}"
                                                             SelectedItem="{Binding ProjectTheme.SelectedTheme}"
                                                             SelectionMode="Single"
                                                             Background="Transparent">
                                                        <ListBox.ItemTemplate>
                                                            <DataTemplate>
                                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                                    <mi:MaterialIcon Kind="ThemeLightDark" Width="16" Height="16" Opacity="0.5"/>
                                                                    <TextBlock Text="{Binding}"/>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </ListBox.ItemTemplate>
                                                    </ListBox>
                                                </ScrollViewer>


                                            </StackPanel>
                                        </TabItem>
                                        
                                        <!-- Zakładka Widok -->
                                        <TabItem Header="{DynamicResource MenuView}" FontSize="11">
                                            <StackPanel Spacing="16" Margin="10">
                                                <TextBlock Text="{DynamicResource SettingsSchematicOptions}" Classes="secondary" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                                
                                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" Margin="0,0,0,8">
                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource SettingsGrid}" VerticalAlignment="Center" Margin="0,0,10,12"/>
                                                    <ToggleSwitch Grid.Row="0" Grid.Column="1" IsChecked="{Binding Schematic.ShowGrid}" OffContent="{DynamicResource SettingsHidden}" OnContent="{DynamicResource SettingsVisible}" Margin="0,0,0,12"/>

                                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource SettingsDinRailAxis}" VerticalAlignment="Center" Margin="0,0,10,12"/>
                                                    <ToggleSwitch Grid.Row="1" Grid.Column="1" IsChecked="{Binding Schematic.ShowDinRailAxis}" OffContent="{DynamicResource SettingsHidden}" OnContent="{DynamicResource SettingsVisible}" Margin="0,0,0,12"/>
                                                    
                                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource SettingsPageNumbers}" VerticalAlignment="Center" Margin="0,0,10,12"/>
                                                    <ToggleSwitch Grid.Row="2" Grid.Column="1" IsChecked="{Binding Schematic.ShowPageNumbers}" OffContent="{DynamicResource SettingsHiddenPlural}" OnContent="{DynamicResource SettingsVisiblePlural}" Margin="0,0,0,12"/>
                                                </Grid>

                                                <Separator Background="{DynamicResource PanelBorder}"/>

                                                <TextBlock Text="{DynamicResource SettingsInterface}" Classes="secondary" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                                
                                                <StackPanel Spacing="8">
                                                    <Grid ColumnDefinitions="*,Auto">
                                                        <TextBlock Text="{DynamicResource SettingsIconSize}" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Schematic.IconSize, StringFormat={}{0:N0} px}" Foreground="{DynamicResource TextSecondary}" FontWeight="Medium"/>
                                                    </Grid>
                                                    <Slider Minimum="24" Maximum="64" Value="{Binding Schematic.IconSize}" TickFrequency="4" IsSnapToTickEnabled="True"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </TabItem>
                                    </TabControl>
                                </Border>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                    <!-- End Settings Button -->
                    
                    


                    

                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL (Modules Palette OR Project Properties) -->
            <Grid Grid.Column="0">
                <views:ModulesPaletteView x:Name="LeftPanel" 
                                          IsModulesEnabled="{Binding Schematic.IsDinRailVisible}"
                                          IsVisible="{Binding Schematic.IsSheet1Active}"/>
                <views:ProjectPropertiesView x:Name="ProjectPanel"
                                             IsVisible="{Binding Schematic.IsSheet2Active}"/>
            </Grid>

            <!-- CANVAS AREA WITH SHEET TABS -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Sheet Tabs (Restored for DEBUG - No Style, No Icons) -->
                <Border Grid.Row="0" Background="{DynamicResource ToolbarBackground}" Padding="4,2">
                    <StackPanel Orientation="Horizontal" Spacing="2">
                        <ToggleButton x:Name="Sheet1Tab" 
                                      IsChecked="{Binding Schematic.IsSheet1Active, Mode=OneWay}"
                                      Command="{Binding Schematic.SwitchToSheet1Command}"
                                      Classes="sheet-tab">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <PathIcon Data="M3,13H11V3H3V13M3,21H11V15H3V21M13,21H21V11H13V21M13,3V9H21V3H13Z" Width="16" Height="16"/>
                                <TextBlock Text="{DynamicResource TabDistributionBoard}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton x:Name="Sheet2Tab"
                                      IsChecked="{Binding Schematic.IsSheet2Active, Mode=OneWay}"
                                      Command="{Binding Schematic.SwitchToSheet2Command}"
                                      Classes="sheet-tab">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <PathIcon Data="M3,3H21V5H3V3M3,7H21V9H3V7M3,11H21V13H3V11M3,15H21V17H3V15" Width="16" Height="16"/>
                                <TextBlock Text="{DynamicResource TabCircuitSchematic}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton x:Name="Sheet3Tab"
                                      IsChecked="{Binding Schematic.IsSheet3Active, Mode=OneWay}"
                                      Command="{Binding Schematic.SwitchToSheet3Command}"
                                      Classes="sheet-tab">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <mi:MaterialIcon Kind="FormatListBulleted" Width="16" Height="16"/>
                                <TextBlock Text="{DynamicResource TabCircuitList}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ToggleButton>

                        <!-- Separator -->
                        <Border Width="1" Background="{DynamicResource PanelBorder}" Margin="6,4" Opacity="0.4"/>

                        <!-- Przełącznik motywu schematu (jasny/ciemny) -->
                        <ToggleButton x:Name="SchematicThemeToggle"
                                      IsChecked="{Binding Schematic.IsSingleLineLightTheme}"
                                      Command="{Binding Schematic.ToggleSingleLineThemeCommand}"
                                      Classes="toolbar-btn"
                                      ToolTip.Tip="{DynamicResource TooltipToggleSchematicTheme}"
                                      IsVisible="{Binding Schematic.IsSheet2Active}"
                                      Padding="6,4">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <mi:MaterialIcon x:Name="SchematicThemeIcon" Kind="WeatherSunny" Width="14" Height="14"/>
                                <TextBlock x:Name="SchematicThemeLabel" Text="{DynamicResource ThemeLight}" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ToggleButton>
                    </StackPanel>
                </Border>
                
                <!-- Sheet Content -->
                <Grid Grid.Row="1">
                    <!-- Sheet 1: Rozdzielnica (existing canvas) -->
                    <Border Background="{DynamicResource AppBackground}" x:Name="CanvasContainer" ClipToBounds="True"
                            DragDrop.AllowDrop="True"
                            IsVisible="{Binding Schematic.IsSheet1Active}">
                
                        <!-- Single child container for Border -->
                        <Grid>
                    <!-- Main Canvas with zoom transform -->
                    <Canvas x:Name="ZoomContainer" HorizontalAlignment="Left" VerticalAlignment="Top"
                            Width="5000" Height="3000" Background="Transparent" RenderTransformOrigin="0,0">
                    <Canvas.RenderTransform>
                        <MatrixTransform/>
                    </Canvas.RenderTransform>

                    <!-- DIN Rail View - directly on Canvas -->
                    <Canvas x:Name="AxisLinesContainer" IsHitTestVisible="False"/>

                    <controls:DinRailView x:Name="DinRailDisplay"
                                          Canvas.Left="0" Canvas.Top="0"
                                          IsVisible="{Binding Schematic.IsDinRailVisible}"
                                          IsHitTestVisible="False"/>



                    <!-- GROUP FRAMES LAYER -->
                    <ItemsControl ItemsSource="{Binding Layout.GroupFrames}"
                                  Canvas.Left="0" Canvas.Top="0"
                                  ClipToBounds="False"
                                  IsHitTestVisible="False">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas ClipToBounds="False"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:GroupFrameInfo">
                                <Grid Width="{Binding Width}" Height="{Binding Height}">
                                    <Border BorderBrush="#883B82F6"
                                            BorderThickness="1.5"
                                            CornerRadius="4"
                                            Background="#0D3B82F6"/>
                                    <Border Background="#CC3B82F6"
                                            CornerRadius="3"
                                            Padding="5,1"
                                            VerticalAlignment="Top"
                                            HorizontalAlignment="Left"
                                            Margin="4,-10,0,0">
                                        <TextBlock Text="{Binding GroupName}"
                                                   FontSize="9"
                                                   FontWeight="Bold"
                                                   Foreground="#FFFFFF"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        <ItemsControl.Styles>
                            <Style Selector="ContentPresenter" x:DataType="models:GroupFrameInfo">
                                <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                <Setter Property="ZIndex" Value="-1"/>
                            </Style>
                        </ItemsControl.Styles>
                    </ItemsControl>

                    <!-- SYMBOLS LAYER -->
                    <ItemsControl x:Name="SymbolsContainer" 
                                  ItemsSource="{Binding Symbols}"
                                  Canvas.Left="0" Canvas.Top="0" 
                                  ClipToBounds="False">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <controls:VirtualizingCanvasPanel ClipToBounds="False"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:SymbolItem">
                                <controls:SymbolControl MainContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        <ItemsControl.Styles>
                            <Style Selector="ContentPresenter" x:DataType="models:SymbolItem">
                                <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                <Setter Property="ZIndex" Value="{Binding IsTerminalBlock, Converter={StaticResource BoolToZIndexConverter}}"/>
                            </Style>
                        </ItemsControl.Styles>
                    </ItemsControl>

                    <!-- MARQUEE SELECTION LAYER -->
                    <Border x:Name="SelectionRectangle"
                            BorderBrush="{DynamicResource AccentBlue}"
                            BorderThickness="1.5"
                            Background="{DynamicResource AccentBlue}"
                            Opacity="0.2"
                            IsVisible="False"
                            CornerRadius="2" />

                    <!-- DRAG PREVIEW OVERLAY -->
                    <Border x:Name="DragPreviewBorder" 
                            IsVisible="False"
                            Opacity="0.85">
                        <Image x:Name="DragPreviewImage" 
                               Width="60" Height="120"
                               Stretch="Uniform"/>
                    </Border>
                    </Canvas>
                    
                    <!-- Validation Hint Primary Action Button - CENTERED over canvas -->
                    <Button Click="BtnDinRail_Click"
                            IsVisible="{Binding !Schematic.IsDinRailVisible}"
                            HorizontalAlignment="Center" 
                            VerticalAlignment="Center"
                            Background="Transparent"
                            BorderBrush="{DynamicResource PanelBorder}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="30,20"
                            Cursor="Hand"
                            Opacity="0.8">
                        <StackPanel Spacing="10">
                            <mi:MaterialIcon Kind="ViewModule" Width="48" Height="48" Foreground="{DynamicResource AccentBlue}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Wygeneruj szynę DIN" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextMain}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Kliknij tutaj lub użyj ikony na pasku narzędzi" FontSize="12" Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    </Grid>
                    </Border>

                    <Border x:Name="Sheet2Container"
                            Background="{DynamicResource AppBackground}" 
                            IsVisible="{Binding Schematic.IsSheet2Active}"
                            Padding="0">
                        <controls:SingleLineDiagramCanvas x:Name="SchematicDiagram" 
                                                            ClipToBounds="True"/>
                    </Border>
                    
                    <Border x:Name="Sheet3Container"
                            Background="{DynamicResource AppBackground}" 
                            IsVisible="{Binding Schematic.IsSheet3Active}"
                            Padding="0">
                        <views:CircuitListView DataContext="{Binding CircuitList}"/>
                    </Border>
                    </Grid>
                </Grid>
            <Border x:Name="RightPanel" Grid.Column="2" Background="{DynamicResource PanelBackground}" BorderThickness="1,0,0,0" BorderBrush="{DynamicResource PanelBorder}"
                    IsVisible="{Binding IsRightPanelVisible}">
                <TabControl x:Name="RightTabControl" Margin="0" Padding="0">
                    <TabControl.Styles>
                        <Style Selector="TabItem">
                            <Setter Property="Padding" Value="8,5"/>
                            <Setter Property="FontSize" Value="11"/>
                        </Style>
                    </TabControl.Styles>
                    
                    <!-- TAB 1: Konfiguracja -->
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <mi:MaterialIcon Kind="Cog" Width="16" Height="16"/>
                                <TextBlock Text="{DynamicResource TabConfiguration}"/>
                            </StackPanel>
                        </TabItem.Header>
                        <views:PowerConfigPanel/>
                    </TabItem>
                    
                    <!-- TAB 2: Obwody -->
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <mi:MaterialIcon Kind="FormatListGroup" Width="16" Height="16"/>
                                <TextBlock Text="{DynamicResource TabCircuitGroups}"/>
                            </StackPanel>
                        </TabItem.Header>
                        <views:GroupedCircuitsPanel/>
                    </TabItem>

                    <!-- TAB 3: Bilans -->
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <mi:MaterialIcon Kind="ChartBar" Width="16" Height="16"/>
                                <TextBlock Text="{DynamicResource TabBalance}"/>
                            </StackPanel>
                        </TabItem.Header>
                        <views:PowerBalancePanel x:Name="PnlPowerBalance"/>
                    </TabItem>

                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <mi:MaterialIcon Kind="AlertCircleOutline" Width="16" Height="16"/>
                                <TextBlock Text="{DynamicResource TabValidation}"/>
                            </StackPanel>
                        </TabItem.Header>
                        <ScrollViewer>
                            <StackPanel Spacing="8" Margin="8">
                                <TextBlock Classes="section-header" Text="{DynamicResource ValidationResults}"/>
                                <Border Classes="card">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="{Binding Validation.ValidationSummary}" FontWeight="SemiBold"/>
                                        <StackPanel Orientation="Horizontal" Spacing="16">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <mi:MaterialIcon Kind="CloseCircleOutline" Width="14" Height="14" Foreground="{DynamicResource AccentRed}"/>
                                                <TextBlock Text="{DynamicResource ValidationErrorsPrefix}" Classes="secondary"/>
                                                <TextBlock Text="{Binding Validation.ValidationErrorCount}" Classes="secondary"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <mi:MaterialIcon Kind="AlertCircleOutline" Width="14" Height="14" Foreground="{DynamicResource AccentOrange}"/>
                                                <TextBlock Text="{DynamicResource ValidationWarningsPrefix}" Classes="secondary"/>
                                                <TextBlock Text="{Binding Validation.ValidationWarningCount}" Classes="secondary"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <Border Classes="card">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="{DynamicResource ValidationMessages}" FontWeight="SemiBold"/>
                                        <ItemsControl ItemsSource="{Binding Validation.ValidationMessages}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Spacing="8"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="services:ValidationMessage">
                                                    <Border Padding="6" Background="{DynamicResource PanelBackgroundAlt}" CornerRadius="4">
                                                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="6">
                                                            <mi:MaterialIcon Width="12" Height="12" Kind="AlertCircleOutline" Foreground="{DynamicResource AccentOrange}"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding Message}" FontWeight="Medium" FontSize="11" TextWrapping="Wrap"/>
                                                            <TextBlock Grid.Column="1" Grid.Row="1" Text="{Binding Details}" Classes="secondary" FontSize="9" TextWrapping="Wrap"/>
                                                            <StackPanel Grid.Column="1" Grid.Row="2" Orientation="Horizontal" Spacing="4">
                                                                <TextBlock Classes="tertiary" FontSize="9" Text="{Binding Severity}"/>
                                                                <TextBlock Classes="tertiary" FontSize="9" Text="·"/>
                                                                <TextBlock Classes="tertiary" FontSize="9" Text="{DynamicResource ValidationCodePrefix}"/>
                                                                <TextBlock Classes="tertiary" FontSize="9" Text=":"/>
                                                                <TextBlock Classes="tertiary" FontSize="9" Text="{Binding Code}"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <TextBlock Text="{DynamicResource ValidationNoMessages}" IsVisible="{Binding Validation.HasValidationMessages, Converter={StaticResource InverseBoolConverter}}" Classes="secondary"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem x:Name="CircuitEditTab">
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <mi:MaterialIcon Kind="Pencil" Width="16" Height="16"/>
                                <TextBlock Text="{DynamicResource TabCircuitEdit}"/>
                            </StackPanel>
                        </TabItem.Header>
                        <views:CircuitEditPanelView x:Name="CircuitEditPanel"/>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>

        <!-- Toast Notification Overlay -->
        <controls:ToastNotification x:Name="Toast" Grid.Row="1" 
                                     IsVisible="False"
                                     HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                     ZIndex="100"/>

        <Border Grid.Row="2" Background="{DynamicResource PanelBackground}" Padding="8,3" 
                BorderBrush="{DynamicResource PanelBorder}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Project name + status -->
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <StackPanel Orientation="Horizontal" Spacing="3">
                        <mi:MaterialIcon Kind="FileDocumentOutline" Width="12" Height="12" Foreground="{DynamicResource TextTertiary}"/>
                        <TextBlock Text="{Binding ProjectFileName}" Classes="secondary" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Ellipse Width="6" Height="6" Fill="{DynamicResource AccentRed}" VerticalAlignment="Center" 
                                 IsVisible="{Binding HasUnsavedChanges}" Margin="2,0,0,0"
                                 ToolTip.Tip="{DynamicResource TooltipUnsavedChanges}"/>
                    </StackPanel>
                    <Border Width="1" Background="{DynamicResource PanelBorder}" Margin="4,1" Opacity="0.3"/>
                    <StackPanel Orientation="Horizontal" Spacing="3">
                        <mi:MaterialIcon Kind="CheckCircle" Width="12" Height="12" Foreground="{DynamicResource AccentGreen}"/>
                        <TextBlock Text="{Binding StatusMessage}" Classes="secondary" FontSize="10" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- Right: Stats -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="14">
                    <StackPanel Orientation="Horizontal" Spacing="3" ToolTip.Tip="{DynamicResource TooltipTotalPower}">
                        <mi:MaterialIcon Kind="LightningBolt" Width="12" Height="12" Foreground="{DynamicResource AccentYellow}"/>
                        <TextBlock Classes="secondary" FontSize="10" VerticalAlignment="Center"
                                   Text="{Binding TotalPowerKW, StringFormat='{}{0:F1} kW'}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="3" ToolTip.Tip="{DynamicResource TooltipGroupCount}">
                        <mi:MaterialIcon Kind="Group" Width="12" Height="12" Foreground="{DynamicResource AccentBlue}"/>
                        <TextBlock Classes="secondary" FontSize="10" VerticalAlignment="Center" Text="{DynamicResource StatusGroupPrefix}"/>
                        <TextBlock Classes="secondary" FontSize="10" VerticalAlignment="Center" Text="{Binding GroupCount}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="3" ToolTip.Tip="{DynamicResource TooltipModuleCount}">
                        <mi:MaterialIcon Kind="Shape" Width="12" Height="12" Classes="tertiary"/>
                        <TextBlock Classes="secondary" FontSize="10" VerticalAlignment="Center" Text="{DynamicResource StatusModulePrefix}"/>
                        <TextBlock Classes="secondary" FontSize="10" VerticalAlignment="Center" Text="{Binding Symbols.Count}"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Home Screen Overlay -->
        <views:HomeScreenView Grid.Row="0" Grid.RowSpan="3" IsVisible="{Binding IsHomeScreenVisible}" ZIndex="999"/>
    </Grid>
</Window>
