<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:DINBoard.ViewModels"
        xmlns:models="using:DINBoard.Models"
        xmlns:views="using:DINBoard.Views"
        xmlns:controls="using:DINBoard.Controls"
        xmlns:converters="using:DINBoard.Converters"
        xmlns:mi="using:Material.Icons.Avalonia"
        xmlns:services="using:DINBoard.Services"
        x:Class="DINBoard.MainWindow"
        x:Name="RootWindow"
        x:DataType="vm:MainViewModel"
        d:DataContext="{x:Static vm:DesignData.MainViewModel}"
        mc:Ignorable="d" d:DesignWidth="1400" d:DesignHeight="800"
        Icon="avares://DINBoard/Assets/app_icon.ico"
        Title="DINBoard"
        WindowState="Maximized"
        Width="1400" Height="900"
        MinWidth="1024" MinHeight="768"
        Background="{DynamicResource AppBackground}">
    
    <Window.Resources>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
        <converters:BoolToZIndexConverter x:Key="BoolToZIndexConverter" TrueValue="5" FalseValue="10"/>
    </Window.Resources>

    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+N" Command="{Binding Workspace.CreateProjectCommand}"/>
        <KeyBinding Gesture="Ctrl+O" Command="{Binding Workspace.LoadCommand}"/>
        <KeyBinding Gesture="Ctrl+S" Command="{Binding Workspace.SaveCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+S" Command="{Binding Workspace.SaveAsCommand}"/>
        <KeyBinding Gesture="Ctrl+Z" Command="{Binding UndoCommand}"/>
        <KeyBinding Gesture="Ctrl+Y" Command="{Binding RedoCommand}"/>
        <KeyBinding Gesture="Ctrl+D" Command="{Binding ModuleManager.DuplicateSelectedCommand}"/>
        <KeyBinding Gesture="Delete" Command="{Binding ModuleManager.DeleteSelectedCommand}"/>
        <KeyBinding Gesture="Ctrl+P" Command="{Binding Exporter.ExportPdfCommand}"/>
    </Window.KeyBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- TOOLBAR -->
        <Border x:Name="ToolbarShell"
                Grid.Row="0"
                Classes="toolbar-shell">
            <Grid RowDefinitions="Auto,Auto,Auto">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: File Operations -->
                <StackPanel Grid.Row="0" Margin="14,10,0,8" Orientation="Horizontal" Spacing="4">
                    
                    <!-- MENU PLIK -->
                    <Button Classes="toolbar-menu-btn active" Content="{DynamicResource MenuFile}" VerticalAlignment="Center">
                        <Button.Flyout>
                            <Flyout Placement="BottomEdgeAlignedLeft" ShowMode="Standard">
                                <Border Classes="toolbar-flyout-shell" Width="304">
                                    <StackPanel Spacing="1">
                                        <TextBlock Classes="toolbar-flyout-section" Text="{DynamicResource MenuProject}"/>
                                        
                                        <!-- Nowy -->
                                        <Button Classes="toolbar-flyout-item" Command="{Binding Workspace.CreateProjectCommand}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="24"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <mi:MaterialIcon Kind="FileDocumentOutline" Width="16" Height="16" Foreground="{DynamicResource TextSecondary}"/>
                                                <TextBlock Grid.Column="1" Text="{DynamicResource MenuNewProject}" Margin="12,0,0,0" Foreground="{DynamicResource TextMain}" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="2" Text="Ctrl+N" Foreground="{DynamicResource TextTertiary}" FontSize="10" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Button>

                                        <!-- Otwórz -->
                                        <Button Classes="toolbar-flyout-item" Command="{Binding Workspace.LoadCommand}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="24"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <mi:MaterialIcon Kind="FolderOpen" Width="16" Height="16" Foreground="{DynamicResource TextSecondary}"/>
                                                <TextBlock Grid.Column="1" Text="{DynamicResource MenuOpen}" Margin="12,0,0,0" Foreground="{DynamicResource TextMain}" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="2" Text="Ctrl+O" Foreground="{DynamicResource TextTertiary}" FontSize="10" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Button>

                                        <!-- Zapisz -->
                                        <Button Classes="toolbar-flyout-item" Command="{Binding Workspace.SaveCommand}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="24"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <mi:MaterialIcon Kind="ContentSave" Width="16" Height="16" Foreground="{DynamicResource TextSecondary}"/>
                                                <TextBlock Grid.Column="1" Text="{DynamicResource MenuSave}" Margin="12,0,0,0" Foreground="{DynamicResource TextMain}" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="2" Text="Ctrl+S" Foreground="{DynamicResource TextTertiary}" FontSize="10" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Button>

                                        <!-- Zapisz jako -->
                                        <Button Classes="toolbar-flyout-item" Command="{Binding Workspace.SaveAsCommand}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="24"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <mi:MaterialIcon Kind="ContentSaveEdit" Width="16" Height="16" Foreground="{DynamicResource TextSecondary}"/>
                                                <TextBlock Grid.Column="1" Text="{DynamicResource MenuSaveAs}" Margin="12,0,0,0" Foreground="{DynamicResource TextMain}" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Button>
                                        
                                        <Rectangle Classes="toolbar-flyout-divider"/>

                                        <!-- EKSPORT -->
                                        <TextBlock Classes="toolbar-flyout-section" Text="{DynamicResource MenuExport}"/>
                                        
                                        <!-- Drukuj -->
                                        <Button Classes="toolbar-flyout-item" Command="{Binding Workspace.PrintCommand}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="24"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <mi:MaterialIcon Kind="Printer" Width="16" Height="16" Foreground="{DynamicResource TextSecondary}"/>
                                                <TextBlock Grid.Column="1" Text="{DynamicResource MenuPrint}" Margin="12,0,0,0" Foreground="{DynamicResource TextMain}" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="2" Text="Ctrl+P" Foreground="{DynamicResource TextTertiary}" FontSize="10" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Button>

                                        <!-- Eksport PDF -->
                                        <Button Classes="toolbar-flyout-item" Command="{Binding Exporter.ExportPdfCommand}">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <TextBlock Text="📄" FontSize="16"/>
                                                <TextBlock Text="{DynamicResource MenuExportPdf}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>

                                        <!-- Eksport PNG (Czysty) -->
                                        <Button Classes="toolbar-flyout-item" Command="{Binding Exporter.ExportPngCleanCommand}">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <TextBlock Text="🖼" FontSize="16"/>
                                                <TextBlock Text="{DynamicResource MenuExportPngClean}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>

                                        <!-- Eksport PNG (Z Oznaczeniami) -->
                                        <Button Classes="toolbar-flyout-item" Command="{Binding Exporter.ExportPngAnnotatedCommand}">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <TextBlock Text="🖍" FontSize="16"/>
                                                <TextBlock Text="{DynamicResource MenuExportPngAnnotated}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>

                                        <!-- Eksport BOM (CSV) -->
                                        <Button Classes="toolbar-flyout-item" Command="{Binding Exporter.ExportBomCommand}">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <TextBlock Text="📋" FontSize="16"/>
                                                <TextBlock Text="{DynamicResource MenuExportBom}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>

                                        <!-- Eksport LaTeX -->
                                        <Button Classes="toolbar-flyout-item" Command="{Binding Exporter.ExportLatexCommand}">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <TextBlock Text="📝" FontSize="16"/>
                                                <TextBlock Text="{DynamicResource MenuExportLatex}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>

                                        <Rectangle Classes="toolbar-flyout-divider"/>
                                        
                                        <!-- Wyjdź -->
                                        <Button Classes="toolbar-flyout-item" Command="{Binding Workspace.ExitCommand}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="24"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <mi:MaterialIcon Kind="ExitToApp" Width="16" Height="16" Foreground="{DynamicResource AccentRed}"/>
                                                <TextBlock Grid.Column="1" Text="{DynamicResource MenuExit}" Margin="12,0,0,0" Foreground="{DynamicResource AccentRed}" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Button>

                                    </StackPanel>
                                </Border>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                    
                    <!-- MENU WIDOK -->
                    <Button Classes="toolbar-menu-btn" Content="{DynamicResource MenuView}" VerticalAlignment="Center">
                        <Button.Flyout>
                            <Flyout Placement="BottomEdgeAlignedLeft" ShowMode="Standard">
                                <Border Classes="toolbar-flyout-shell" Width="284">
                                    <StackPanel Spacing="1">
                                        <TextBlock Classes="toolbar-flyout-section" Text="{DynamicResource MenuDisplayOptions}"/>
                                        
                                        <!-- Toggle prawy panel -->
                                        <Button Classes="toolbar-flyout-item" Command="{Binding ToggleRightPanelCommand}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="24"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <mi:MaterialIcon Kind="DockRight" Width="16" Height="16" Foreground="{DynamicResource TextSecondary}"/>
                                                <TextBlock Grid.Column="1" Text="{DynamicResource MenuRightPanel}" Margin="12,0,0,0" Foreground="{DynamicResource TextMain}" VerticalAlignment="Center"/>
                                                <mi:MaterialIcon Grid.Column="2" Kind="Check" Width="14" Height="14" 
                                                                 Foreground="{DynamicResource AccentGreen}"
                                                                 IsVisible="{Binding IsRightPanelVisible}"/>
                                            </Grid>
                                        </Button>

                                        <Rectangle Classes="toolbar-flyout-divider"/>
                                        
                                        <TextBlock Classes="toolbar-flyout-section" Text="{DynamicResource MenuSheets}"/>
                                        
                                        <!-- Sheet 1: Szyna DIN -->
                                        <Button Classes="toolbar-flyout-item" Command="{Binding Schematic.SwitchToSheet1Command}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="24"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <mi:MaterialIcon Kind="ViewModule" Width="16" Height="16" Foreground="{DynamicResource TextSecondary}"/>
                                                <TextBlock Grid.Column="1" Text="{DynamicResource MenuSheet1}" Margin="12,0,0,0" Foreground="{DynamicResource TextMain}" VerticalAlignment="Center"/>
                                                <mi:MaterialIcon Grid.Column="2" Kind="Check" Width="14" Height="14" 
                                                                 Foreground="{DynamicResource AccentGreen}"
                                                                 IsVisible="{Binding Schematic.IsSheet1Active}"/>
                                            </Grid>
                                        </Button>
                                        
                                        <!-- Sheet 2: Schemat jednokreskowy -->
                                        <Button Classes="toolbar-flyout-item" Command="{Binding Schematic.SwitchToSheet2Command}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="24"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <mi:MaterialIcon Kind="FileTreeOutline" Width="16" Height="16" Foreground="{DynamicResource TextSecondary}"/>
                                                <TextBlock Grid.Column="1" Text="{DynamicResource MenuSheet2}" Margin="12,0,0,0" Foreground="{DynamicResource TextMain}" VerticalAlignment="Center"/>
                                                <mi:MaterialIcon Grid.Column="2" Kind="Check" Width="14" Height="14" 
                                                                 Foreground="{DynamicResource AccentGreen}"
                                                                 IsVisible="{Binding Schematic.IsSheet2Active}"/>
                                            </Grid>
                                        </Button>

                                        <!-- Sheet 3: Lista obwodow -->
                                        <Button Classes="toolbar-flyout-item" Command="{Binding Schematic.SwitchToSheet3Command}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="24"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <mi:MaterialIcon Kind="FormatListBulleted" Width="16" Height="16" Foreground="{DynamicResource TextSecondary}"/>
                                                <TextBlock Grid.Column="1" Text="Lista obwodow" Margin="12,0,0,0" Foreground="{DynamicResource TextMain}" VerticalAlignment="Center"/>
                                                <mi:MaterialIcon Grid.Column="2" Kind="Check" Width="14" Height="14" 
                                                                 Foreground="{DynamicResource AccentGreen}"
                                                                 IsVisible="{Binding Schematic.IsSheet3Active}"/>
                                            </Grid>
                                        </Button>

                                        <!-- Sheet 4: Podglad PDF -->
                                        <Button Classes="toolbar-flyout-item" Command="{Binding Schematic.SwitchToSheet4Command}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="24"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <mi:MaterialIcon Kind="FilePdfBox" Width="16" Height="16" Foreground="{DynamicResource TextSecondary}"/>
                                                <TextBlock Grid.Column="1" Text="Podglad PDF" Margin="12,0,0,0" Foreground="{DynamicResource TextMain}" VerticalAlignment="Center"/>
                                                <mi:MaterialIcon Grid.Column="2" Kind="Check" Width="14" Height="14" 
                                                                 Foreground="{DynamicResource AccentGreen}"
                                                                 IsVisible="{Binding Schematic.IsSheet4Active}"/>
                                            </Grid>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                    <Button Classes="toolbar-menu-btn" Content="{DynamicResource MenuTools}" VerticalAlignment="Center">
                        <Button.Flyout>
                            <Flyout Placement="BottomEdgeAlignedLeft" ShowMode="Standard">
                                <Border Classes="toolbar-flyout-shell" Width="284">
                                    <StackPanel Spacing="1">
                                        <TextBlock Classes="toolbar-flyout-section" Text="{DynamicResource MenuToolsSection}"/>

                                        <Button Classes="toolbar-flyout-item" Click="BtnDinRail_Click">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="24"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <mi:MaterialIcon Kind="ViewModule" Width="16" Height="16" Foreground="{DynamicResource AccentBlue}"/>
                                                <TextBlock Grid.Column="1" Text="{DynamicResource ToolDinRail}" Margin="12,0,0,0" Foreground="{DynamicResource TextMain}" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Button>

                                        <Button Classes="toolbar-flyout-item" Command="{Binding GenerateBusbarCommand}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="24"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <mi:MaterialIcon Kind="PowerPlug" Width="16" Height="16" Foreground="{DynamicResource TextSecondary}"/>
                                                <TextBlock Grid.Column="1" Text="{DynamicResource ToolBusbar}" Margin="12,0,0,0" Foreground="{DynamicResource TextMain}" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Button>

                                        <Button Classes="toolbar-flyout-item" Click="BtnImportModules_Click">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="24"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <mi:MaterialIcon Kind="FileImport" Width="16" Height="16" Foreground="{DynamicResource TextSecondary}"/>
                                                <TextBlock Grid.Column="1" Text="{DynamicResource ToolImportSvg}" Margin="12,0,0,0" Foreground="{DynamicResource TextMain}" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                    <Button Classes="toolbar-menu-btn"
                            Content="{DynamicResource MenuHelp}"
                            VerticalAlignment="Center"
                            Click="BtnHelp_Click"/>

                </StackPanel>

                <Border Grid.Row="1" Grid.ColumnSpan="3" Height="1" Background="{DynamicResource PanelBorder}" Opacity="0.9"/>

                <StackPanel Grid.Row="2" Grid.ColumnSpan="3" Margin="14,10,14,12" Orientation="Horizontal" Spacing="4">

                    <Button Classes="toolbar-icon-btn" Command="{Binding UndoCommand}" ToolTip.Tip="{DynamicResource TooltipUndo}">
                        <mi:MaterialIcon Kind="Undo" Width="14" Height="14" Foreground="{DynamicResource TextSecondary}"/>
                    </Button>
                    <Button Classes="toolbar-icon-btn" Command="{Binding RedoCommand}" ToolTip.Tip="{DynamicResource TooltipRedo}">
                        <mi:MaterialIcon Kind="Redo" Width="14" Height="14" Foreground="{DynamicResource TextSecondary}"/>
                    </Button>

                    <Border Width="1" Height="20" Background="{DynamicResource PanelBorder}" Margin="6,0" Opacity="0.5"/>

                    <Button Classes="toolbar-icon-btn" Command="{Binding ModuleManager.DeleteSelectedCommand}" ToolTip.Tip="{DynamicResource TooltipDeleteSelected}">
                        <mi:MaterialIcon Kind="TrashCanOutline" Width="14" Height="14" Foreground="{DynamicResource AccentRed}"/>
                    </Button>

                    <Button Classes="toolbar-icon-btn" x:Name="BtnDinRail" Click="BtnDinRail_Click" ToolTip.Tip="{DynamicResource ToolDinRail}">
                        <mi:MaterialIcon Kind="ViewModule" Width="14" Height="14" Foreground="{DynamicResource AccentBlue}"/>
                    </Button>
                    <Button Classes="toolbar-icon-btn" x:Name="BtnImportModules" Click="BtnImportModules_Click" ToolTip.Tip="{DynamicResource ToolImportSvg}">
                        <mi:MaterialIcon Kind="FileImport" Width="14" Height="14" Foreground="{DynamicResource TextSecondary}"/>
                    </Button>

                    <Border Width="1" Height="20" Background="{DynamicResource PanelBorder}" Margin="6,0" Opacity="0.5"/>

                    <Button Classes="toolbar-icon-btn" x:Name="BtnZoomIn" Click="BtnZoomIn_Click" ToolTip.Tip="{DynamicResource TooltipZoomIn}">
                        <mi:MaterialIcon Kind="MagnifyPlus" Width="14" Height="14" Foreground="{DynamicResource TextSecondary}"/>
                    </Button>
                    <Border Classes="toolbar-zoom-badge" VerticalAlignment="Center">
                        <TextBlock Text="{DynamicResource ToolbarZoomPercent}" FontSize="10" Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Center"/>
                    </Border>
                    <Button Classes="toolbar-icon-btn" x:Name="BtnZoomOut" Click="BtnZoomOut_Click" ToolTip.Tip="{DynamicResource TooltipZoomOut}">
                        <mi:MaterialIcon Kind="MagnifyMinus" Width="14" Height="14" Foreground="{DynamicResource TextSecondary}"/>
                    </Button>
                    <Button Classes="toolbar-icon-btn" x:Name="BtnZoomFit" Click="BtnZoomFit_Click" ToolTip.Tip="{DynamicResource TooltipZoomFit}">
                        <mi:MaterialIcon Kind="CropFree" Width="14" Height="14" Foreground="{DynamicResource AccentBlue}"/>
                    </Button>

                    </StackPanel>
                
                <!-- Right: Project & Settings -->
                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,10,14,8" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock Classes="toolbar-project-name" Text="{Binding ProjectFileName}" MaxWidth="280" TextTrimming="CharacterEllipsis"/>

                    <Button Classes="toolbar-icon-btn" ToolTip.Tip="{DynamicResource ToolSettings}">
                        <mi:MaterialIcon Kind="Cog" Width="16" Height="16" Foreground="{DynamicResource TextSecondary}"/>
                        <Button.Flyout>
                            <Flyout Placement="BottomEdgeAlignedRight" ShowMode="Standard">
                                <Border Classes="toolbar-flyout-shell" Width="320">
                                    <ScrollViewer MaxHeight="430">
                                        <StackPanel Spacing="1">
                                        <!-- Zakładka Motywy -->
                                            <TextBlock Classes="toolbar-flyout-section" Text="{DynamicResource SettingsAppearanceSection}"/>
                                            <Border Classes="toolbar-flyout-card">
                                                <StackPanel Spacing="8">
                                                    <TextBlock Text="{DynamicResource SettingsSelectTheme}" FontSize="11" Classes="secondary"/>
                                                    <ComboBox ItemsSource="{Binding ProjectTheme.AvailableThemes}"
                                                              SelectedItem="{Binding ProjectTheme.SelectedTheme}"
                                                              HorizontalAlignment="Stretch">
                                                        <ComboBox.ItemTemplate>
                                                            <DataTemplate>
                                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                                    <mi:MaterialIcon Kind="ThemeLightDark" Width="16" Height="16" Opacity="0.55"/>
                                                                    <TextBlock Text="{Binding}"/>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </ComboBox.ItemTemplate>
                                                    </ComboBox>
                                                </StackPanel>
                                            </Border>

                                            <Rectangle Classes="toolbar-flyout-divider"/>
                                        
                                        <!-- Zakładka Widok -->
                                            <TextBlock Classes="toolbar-flyout-section" Text="{DynamicResource SettingsSchematicOptions}" IsVisible="False"/>
                                            <Border Classes="toolbar-flyout-card" IsVisible="False">
                                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource SettingsGrid}" VerticalAlignment="Center" Margin="0,0,10,12"/>
                                                    <ToggleSwitch Grid.Row="0" Grid.Column="1" IsChecked="{Binding Schematic.ShowGrid}" OffContent="{DynamicResource SettingsHidden}" OnContent="{DynamicResource SettingsVisible}" Margin="0,0,0,12"/>

                                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource SettingsDinRailAxis}" VerticalAlignment="Center" Margin="0,0,10,12"/>
                                                    <ToggleSwitch Grid.Row="1" Grid.Column="1" IsChecked="{Binding Schematic.ShowDinRailAxis}" OffContent="{DynamicResource SettingsHidden}" OnContent="{DynamicResource SettingsVisible}" Margin="0,0,0,12"/>

                                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource SettingsPageNumbers}" VerticalAlignment="Center"/>
                                                    <ToggleSwitch Grid.Row="2" Grid.Column="1" IsChecked="{Binding Schematic.ShowPageNumbers}" OffContent="{DynamicResource SettingsHiddenPlural}" OnContent="{DynamicResource SettingsVisiblePlural}"/>
                                                </Grid>
                                            </Border>

                                            <TextBlock Classes="toolbar-flyout-section" Text="{DynamicResource SettingsInterface}"/>
                                            <Border Classes="toolbar-flyout-card">
                                                <StackPanel Spacing="8">
                                                    <Grid ColumnDefinitions="*,Auto">
                                                        <TextBlock Text="{DynamicResource SettingsIconSize}" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Schematic.IconSize, StringFormat={}{0:N0} px}" Foreground="{DynamicResource TextSecondary}" FontWeight="Medium"/>
                                                    </Grid>
                                                    <Slider Minimum="24" Maximum="64" Value="{Binding Schematic.IconSize}" TickFrequency="4" IsSnapToTickEnabled="True"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Border>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                    <!-- End Settings Button -->
                    
                    


                    

                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid x:Name="MainContentShell"
              Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL (Modules Palette OR Project Properties) -->
            <Grid Grid.Column="0">
                <views:ModulesPaletteView x:Name="LeftPanel" 
                                          IsModulesEnabled="{Binding Schematic.IsDinRailVisible}"
                                          IsVisible="{Binding Schematic.IsSheet1Active}"/>
                <views:ProjectPropertiesView x:Name="ProjectPanel"
                                             IsVisible="{Binding Schematic.IsSheet2Active}"/>
            </Grid>

            <!-- CANVAS AREA WITH SHEET TABS -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Workspace Tabs -->
                <Border Grid.Row="0" Classes="workspace-tabs-bar">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                        <ToggleButton x:Name="Sheet1Tab" 
                                      IsChecked="{Binding Schematic.IsSheet1Active, Mode=OneWay}"
                                      Command="{Binding Schematic.SwitchToSheet1Command}"
                                      Classes="sheet-tab">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <mi:MaterialIcon Kind="ViewModule"
                                                 Width="16"
                                                 Height="16"
                                                 Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                                <TextBlock Text="{DynamicResource TabDistributionBoard}"
                                           VerticalAlignment="Center"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton x:Name="Sheet2Tab"
                                      IsChecked="{Binding Schematic.IsSheet2Active, Mode=OneWay}"
                                      Command="{Binding Schematic.SwitchToSheet2Command}"
                                      Classes="sheet-tab">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <mi:MaterialIcon Kind="FileTreeOutline"
                                                 Width="16"
                                                 Height="16"
                                                 Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                                <TextBlock Text="{DynamicResource TabCircuitSchematic}"
                                           VerticalAlignment="Center"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton x:Name="Sheet3Tab"
                                      IsChecked="{Binding Schematic.IsSheet3Active, Mode=OneWay}"
                                      Command="{Binding Schematic.SwitchToSheet3Command}"
                                      Classes="sheet-tab">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <mi:MaterialIcon Kind="FormatListBulleted"
                                                 Width="16"
                                                 Height="16"
                                                 Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                                <TextBlock Text="{DynamicResource TabCircuitList}"
                                           VerticalAlignment="Center"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton x:Name="Sheet4Tab"
                                      IsChecked="{Binding Schematic.IsSheet4Active, Mode=OneWay}"
                                      Command="{Binding Schematic.SwitchToSheet4Command}"
                                      Classes="sheet-tab">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <mi:MaterialIcon Kind="FilePdfBox"
                                                 Width="16"
                                                 Height="16"
                                                 Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                                <TextBlock Text="Podglad PDF"
                                           VerticalAlignment="Center"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                            </StackPanel>
                        </ToggleButton>

                        <Border Classes="workspace-tab-separator"/>
                        </StackPanel>

                        <!-- Przełącznik motywu schematu (jasny/ciemny) -->
                        <ToggleButton x:Name="SchematicThemeToggle"
                                      Grid.Column="2"
                                      IsChecked="{Binding Schematic.IsSingleLineLightTheme}"
                                      Command="{Binding Schematic.ToggleSingleLineThemeCommand}"
                                      Classes="toolbar-btn"
                                      ToolTip.Tip="{DynamicResource TooltipToggleSchematicTheme}"
                                      IsVisible="{Binding Schematic.IsSheet2Active}"
                                      Margin="10,0,0,0"
                                      VerticalAlignment="Center"
                                      Padding="6,4">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <mi:MaterialIcon x:Name="SchematicThemeIcon" Kind="WeatherSunny" Width="14" Height="14"/>
                                <TextBlock x:Name="SchematicThemeLabel" Text="{DynamicResource ThemeLight}" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ToggleButton>
                    </Grid>
                </Border>
                
                <!-- Sheet Content -->
                <Grid Grid.Row="1">
                    <!-- Sheet 1: Rozdzielnica (existing canvas) -->
                    <Border Background="{DynamicResource AppBackground}" x:Name="CanvasContainer" ClipToBounds="True"
                            DragDrop.AllowDrop="True"
                            IsVisible="{Binding Schematic.IsSheet1Active}">
                
                        <!-- Single child container for Border -->
                        <Grid>
                    <!-- Main Canvas with zoom transform -->
                    <Canvas x:Name="ZoomContainer" HorizontalAlignment="Left" VerticalAlignment="Top"
                            Width="5000" Height="3000" Background="Transparent" RenderTransformOrigin="0,0">
                    <Canvas.RenderTransform>
                        <MatrixTransform/>
                    </Canvas.RenderTransform>

                    <!-- DIN Rail View - directly on Canvas -->
                    <Canvas x:Name="AxisLinesContainer" IsHitTestVisible="False"/>

                    <controls:DinRailView x:Name="DinRailDisplay"
                                          Canvas.Left="0" Canvas.Top="0"
                                          IsVisible="{Binding Schematic.IsDinRailVisible}"
                                          IsHitTestVisible="False"/>



                    <!-- GROUP FRAMES LAYER -->
                    <ItemsControl ItemsSource="{Binding Layout.GroupFrames}"
                                  Canvas.Left="0" Canvas.Top="0"
                                  ClipToBounds="False"
                                  IsHitTestVisible="False">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas ClipToBounds="False"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:GroupFrameInfo">
                                <Grid Width="{Binding Width}" Height="{Binding Height}">
                                    <Border BorderBrush="#883B82F6"
                                            BorderThickness="1.5"
                                            CornerRadius="4"
                                            Background="#0D3B82F6"
                                            IsHitTestVisible="False"/>
                                    <Border Background="#CC3B82F6"
                                            CornerRadius="3"
                                            Padding="5,1"
                                            VerticalAlignment="Top"
                                            HorizontalAlignment="Left"
                                            Margin="4,-10,0,0"
                                            IsHitTestVisible="False">
                                        <TextBlock Text="{Binding GroupName}"
                                                   FontSize="9"
                                                   FontWeight="Bold"
                                                   Foreground="#FFFFFF"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        <ItemsControl.Styles>
                            <Style Selector="ContentPresenter" x:DataType="models:GroupFrameInfo">
                                <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                <Setter Property="ZIndex" Value="-1"/>
                            </Style>
                        </ItemsControl.Styles>
                    </ItemsControl>

                    <!-- SYMBOLS LAYER -->
                    <ItemsControl x:Name="SymbolsContainer" 
                                  ItemsSource="{Binding Symbols}"
                                  Canvas.Left="0" Canvas.Top="0" 
                                  ClipToBounds="False">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <controls:VirtualizingCanvasPanel ClipToBounds="False"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:SymbolItem">
                                <controls:SymbolControl MainContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        <ItemsControl.Styles>
                            <Style Selector="ContentPresenter" x:DataType="models:SymbolItem">
                                <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                <Setter Property="ZIndex" Value="{Binding IsTerminalBlock, Converter={StaticResource BoolToZIndexConverter}}"/>
                            </Style>
                        </ItemsControl.Styles>
                    </ItemsControl>

                    <!-- MARQUEE SELECTION LAYER -->
                    <Border x:Name="SelectionRectangle"
                            BorderBrush="{DynamicResource AccentBlue}"
                            BorderThickness="1.5"
                            Background="{DynamicResource AccentBlue}"
                            Opacity="0.2"
                            IsVisible="False"
                            CornerRadius="2" />

                    <!-- DRAG PREVIEW OVERLAY -->
                    <Border x:Name="DragPreviewBorder" 
                            IsVisible="False"
                            Opacity="0.85">
                        <Image x:Name="DragPreviewImage" 
                               Width="60" Height="120"
                               Stretch="Uniform"/>
                    </Border>
                    </Canvas>
                    
                    <!-- Validation Hint Primary Action Button - CENTERED over canvas -->
                    <Button Click="BtnDinRail_Click"
                            IsVisible="{Binding !Schematic.IsDinRailVisible}"
                            HorizontalAlignment="Center" 
                            VerticalAlignment="Center"
                            Background="Transparent"
                            BorderBrush="{DynamicResource PanelBorder}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="30,20"
                            Cursor="Hand"
                            Opacity="0.8">
                        <StackPanel Spacing="10">
                            <mi:MaterialIcon Kind="ViewModule" Width="48" Height="48" Foreground="{DynamicResource AccentBlue}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Wygeneruj szynę DIN" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextMain}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Kliknij tutaj lub użyj ikony na pasku narzędzi" FontSize="12" Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    </Grid>
                    </Border>

                    <Border x:Name="Sheet2Container"
                            Background="{DynamicResource AppBackground}" 
                            IsVisible="{Binding Schematic.IsSheet2Active}"
                            Padding="0">
                        <controls:SingleLineDiagramCanvas x:Name="SchematicDiagram" 
                                                            ClipToBounds="True"/>
                    </Border>
                    
                    <Border x:Name="Sheet3Container"
                            Background="{DynamicResource AppBackground}" 
                            IsVisible="{Binding Schematic.IsSheet3Active}"
                            Padding="0">
                        <views:CircuitListView DataContext="{Binding CircuitList}"/>
                    </Border>

                    <Border x:Name="Sheet4Container"
                            Background="{DynamicResource AppBackground}" 
                            IsVisible="{Binding Schematic.IsSheet4Active}"
                            Padding="0">
                        <views:PdfPreviewView DataContext="{Binding Exporter}"/>
                    </Border>
                    </Grid>
                </Grid>
            <Border x:Name="RightPanel" Grid.Column="2" Background="{DynamicResource PanelBackground}" BorderThickness="1,0,0,0" BorderBrush="{DynamicResource PanelBorder}"
                    IsVisible="{Binding IsRightPanelVisible}">
                    <Grid Margin="12" RowDefinitions="Auto,Auto,*">
                            <TextBlock Text="{DynamicResource HeaderRightPanelProperties}"
                                       Margin="4,2,4,12"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMain}"/>
                            <Border Grid.Row="1" Height="1" Background="{DynamicResource PanelBorder}" Opacity="0.8"/>
                            <TabControl x:Name="RightTabControl"
                                        Grid.Row="2"
                                        Margin="0,14,0,0"
                                        Padding="0"
                                        Background="Transparent"
                                        BorderThickness="0">
                                <TabControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" Margin="0,0,0,10"/>
                                    </ItemsPanelTemplate>
                                </TabControl.ItemsPanel>
                                <TabControl.Styles>
                            <Style Selector="TabItem">
                                <Setter Property="Padding" Value="14,8"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Margin" Value="0,0,8,8"/>
                                <Setter Property="ZIndex" Value="1"/>
                                <Setter Property="Background" Value="{DynamicResource PanelBackgroundAlt}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                                <Setter Property="Tag" Value="{DynamicResource TextSecondary}"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="CornerRadius" Value="8"/>
                                <Setter Property="MinWidth" Value="56"/>
                                <Setter Property="MinHeight" Value="36"/>
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                <Setter Property="Transitions">
                                    <Transitions>
                                        <BrushTransition Property="Background" Duration="0:0:0.12"/>
                                        <BrushTransition Property="BorderBrush" Duration="0:0:0.12"/>
                                        <BrushTransition Property="Foreground" Duration="0:0:0.12"/>
                                    </Transitions>
                                </Setter>
                            </Style>
                            <Style Selector="TabItem:pointerover">
                                <Setter Property="Background" Value="{DynamicResource PanelBackgroundAlt}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
                                <Setter Property="Tag" Value="{DynamicResource TextMain}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource PanelBorder}"/>
                            </Style>
                            <Style Selector="TabItem:selected">
                                <Setter Property="Background" Value="{DynamicResource PanelBackgroundAlt}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
                                <Setter Property="Tag" Value="{DynamicResource AccentBlue}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
                            </Style>
                        </TabControl.Styles>
                    
                    <!-- TAB 1: Konfiguracja -->
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <mi:MaterialIcon Kind="Cog"
                                                 Width="16"
                                                 Height="16"
                                                 Foreground="{Binding Tag, RelativeSource={RelativeSource AncestorType=TabItem}}"/>
                                <TextBlock Text="{DynamicResource TabConfiguration}"
                                           TextWrapping="NoWrap"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}"/>
                            </StackPanel>
                        </TabItem.Header>
                        <Border Margin="0,10,0,0" Background="Transparent">
                            <views:PowerConfigPanel/>
                        </Border>
                    </TabItem>
                    
                    <!-- TAB 2: Bilans -->
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <mi:MaterialIcon Kind="ChartBar"
                                                 Width="16"
                                                 Height="16"
                                                 Foreground="{Binding Tag, RelativeSource={RelativeSource AncestorType=TabItem}}"/>
                                <TextBlock Text="{DynamicResource TabBalance}"
                                           TextWrapping="NoWrap"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}"/>
                            </StackPanel>
                        </TabItem.Header>
                        <Border Margin="0,10,0,0" Background="Transparent">
                            <views:PowerBalancePanel x:Name="PnlPowerBalance"/>
                        </Border>
                    </TabItem>

                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <mi:MaterialIcon Kind="InformationOutline"
                                                 Width="16"
                                                 Height="16"
                                                 Foreground="{Binding Tag, RelativeSource={RelativeSource AncestorType=TabItem}}"/>
                                <TextBlock Text="{DynamicResource TabValidation}"
                                           TextWrapping="NoWrap"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}"/>
                            </StackPanel>
                        </TabItem.Header>
                        <Border Margin="0,10,0,0" Background="Transparent">
                        <ScrollViewer>
                            <StackPanel Spacing="8" Margin="8">
                                <TextBlock Classes="section-header" Text="{DynamicResource ValidationResults}"/>
                                <Border Classes="card">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="{Binding Validation.ValidationSummary}" FontWeight="SemiBold"/>
                                        <StackPanel Orientation="Horizontal" Spacing="16">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <mi:MaterialIcon Kind="CloseCircleOutline" Width="14" Height="14" Foreground="{DynamicResource AccentRed}"/>
                                                <TextBlock Text="{DynamicResource ValidationErrorsPrefix}" Classes="secondary"/>
                                                <TextBlock Text="{Binding Validation.ValidationErrorCount}" Classes="secondary"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <mi:MaterialIcon Kind="AlertCircleOutline" Width="14" Height="14" Foreground="{DynamicResource AccentOrange}"/>
                                                <TextBlock Text="{DynamicResource ValidationWarningsPrefix}" Classes="secondary"/>
                                                <TextBlock Text="{Binding Validation.ValidationWarningCount}" Classes="secondary"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <Border Classes="card">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="{DynamicResource ValidationMessages}" FontWeight="SemiBold"/>
                                        <ItemsControl ItemsSource="{Binding Validation.ValidationMessages}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Spacing="8"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="services:ValidationMessage">
                                                    <Border Padding="6" Background="{DynamicResource PanelBackgroundAlt}" CornerRadius="4">
                                                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="6">
                                                            <mi:MaterialIcon Width="12" Height="12" Kind="AlertCircleOutline" Foreground="{DynamicResource AccentOrange}"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding Message}" FontWeight="Medium" FontSize="11" TextWrapping="Wrap"/>
                                                            <TextBlock Grid.Column="1" Grid.Row="1" Text="{Binding Details}" Classes="secondary" FontSize="9" TextWrapping="Wrap"/>
                                                            <StackPanel Grid.Column="1" Grid.Row="2" Orientation="Horizontal" Spacing="4">
                                                                <TextBlock Classes="tertiary" FontSize="9" Text="{Binding Severity}"/>
                                                                <TextBlock Classes="tertiary" FontSize="9" Text="·"/>
                                                                <TextBlock Classes="tertiary" FontSize="9" Text="{DynamicResource ValidationCodePrefix}"/>
                                                                <TextBlock Classes="tertiary" FontSize="9" Text=":"/>
                                                                <TextBlock Classes="tertiary" FontSize="9" Text="{Binding Code}"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <TextBlock Text="{DynamicResource ValidationNoMessages}" IsVisible="{Binding Validation.HasValidationMessages, Converter={StaticResource InverseBoolConverter}}" Classes="secondary"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                        </Border>
                    </TabItem>

                    <TabItem x:Name="CircuitEditTab">
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <mi:MaterialIcon Kind="Pencil"
                                                 Width="16"
                                                 Height="16"
                                                 Foreground="{Binding Tag, RelativeSource={RelativeSource AncestorType=TabItem}}"/>
                                <TextBlock Text="{DynamicResource TabCircuitEdit}"
                                           TextWrapping="NoWrap"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}"/>
                            </StackPanel>
                        </TabItem.Header>
                        <Border Margin="0,10,0,0" Background="Transparent">
                            <views:CircuitEditPanelView x:Name="CircuitEditPanel"/>
                        </Border>
                    </TabItem>
                            </TabControl>
                    </Grid>
            </Border>
        </Grid>

        <!-- Toast Notification Overlay -->
        <controls:ToastNotification x:Name="Toast" Grid.Row="1" 
                                     IsVisible="False"
                                     IsHitTestVisible="{Binding IsHomeScreenVisible, Converter={StaticResource InverseBoolConverter}}"
                                     HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                     ZIndex="100"/>

        <Border x:Name="StatusBarShell"
                Grid.Row="2"
                Background="{DynamicResource PanelBackground}" Padding="8,3" 
                BorderBrush="{DynamicResource PanelBorder}" BorderThickness="0,1,0,0">
            <Grid RowDefinitions="Auto,Auto">
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Project name + status -->
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <StackPanel Orientation="Horizontal" Spacing="3">
                            <mi:MaterialIcon Kind="FileDocumentOutline" Width="12" Height="12" Foreground="{DynamicResource TextTertiary}"/>
                            <TextBlock Text="{Binding ProjectFileName}" Classes="secondary" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <Ellipse Width="6" Height="6" Fill="{DynamicResource AccentRed}" VerticalAlignment="Center"
                                     IsVisible="{Binding HasUnsavedChanges}" Margin="2,0,0,0"
                                     ToolTip.Tip="{DynamicResource TooltipUnsavedChanges}"/>
                        </StackPanel>
                        <Border Width="1" Background="{DynamicResource PanelBorder}" Margin="4,1" Opacity="0.3"/>
                        <StackPanel Orientation="Horizontal" Spacing="3">
                            <mi:MaterialIcon Kind="CheckCircle" Width="12" Height="12" Foreground="{DynamicResource AccentGreen}"/>
                            <TextBlock Text="{Binding StatusMessage}" Classes="secondary" FontSize="10" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Right: Stats -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="14">
                        <StackPanel Orientation="Horizontal" Spacing="3" ToolTip.Tip="{DynamicResource TooltipTotalPower}">
                            <mi:MaterialIcon Kind="LightningBolt" Width="12" Height="12" Foreground="{DynamicResource AccentYellow}"/>
                            <TextBlock Classes="secondary" FontSize="10" VerticalAlignment="Center"
                                       Text="{Binding TotalPowerKW, StringFormat='{}{0:F1} kW'}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="3" ToolTip.Tip="{DynamicResource TooltipGroupCount}">
                            <mi:MaterialIcon Kind="Group" Width="12" Height="12" Foreground="{DynamicResource AccentBlue}"/>
                            <TextBlock Classes="secondary" FontSize="10" VerticalAlignment="Center" Text="{DynamicResource StatusGroupPrefix}"/>
                            <TextBlock Classes="secondary" FontSize="10" VerticalAlignment="Center" Text="{Binding GroupCount}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="3" ToolTip.Tip="{DynamicResource TooltipModuleCount}">
                            <mi:MaterialIcon Kind="Shape" Width="12" Height="12" Classes="tertiary"/>
                            <TextBlock Classes="secondary" FontSize="10" VerticalAlignment="Center" Text="{DynamicResource StatusModulePrefix}"/>
                            <TextBlock Classes="secondary" FontSize="10" VerticalAlignment="Center" Text="{Binding Symbols.Count}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1"
                        IsVisible="{Binding Exporter.IsExportInProgress}"
                        Margin="0,6,0,0"
                        Padding="8,6"
                        CornerRadius="6"
                        Background="{DynamicResource PanelBackgroundAlt}"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource PanelBorder}">
                    <StackPanel Spacing="4">
                        <Grid ColumnDefinitions="170,*,Auto" ColumnSpacing="8">
                            <ProgressBar Height="6"
                                         Minimum="0"
                                         Maximum="100"
                                         Value="{Binding Exporter.ExportProgressPercent}"
                                         VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Exporter.ExportProgressStage}"
                                       Classes="secondary"
                                       FontSize="10"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding Exporter.ExportProgressPercent, StringFormat='{}{0}%'}"
                                       Classes="secondary"
                                       FontSize="10"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock Text="{Binding Exporter.ExportLongOperationReason}"
                                   Classes="tertiary"
                                   FontSize="9"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Home Screen Overlay -->
    </Grid>
</Window>


