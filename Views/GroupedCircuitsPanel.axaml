<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="using:DINBoard.Converters"
             xmlns:mi="using:Material.Icons.Avalonia"
             xmlns:controls="using:DINBoard.Controls"
             xmlns:models="using:DINBoard.Models"
             xmlns:vm="using:DINBoard.ViewModels"
             x:Class="DINBoard.Views.GroupedCircuitsPanel"
             x:Name="Root"
             x:DataType="vm:MainViewModel"
             mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="600">

    <UserControl.Resources>
        <!-- Phase Radio Button Theme -->
        <ControlTheme x:Key="PhaseRadioButtonTheme" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextTertiary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderDefault}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="CornerRadius" Value="9"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="RootBorder" 
                            Background="Transparent" 
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="8,4"
                            Cursor="Hand">
                        <ContentPresenter Content="{TemplateBinding Content}" 
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
            
            <Style Selector="^:checked">
                <Setter Property="Background" Value="{DynamicResource AccentOrange}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource AccentOrange}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontWeight" Value="Bold"/>
            </Style>
            
            <Style Selector="^:pointerover /template/ Border#RootBorder">
                <Setter Property="BorderBrush" Value="{DynamicResource AccentOrange}"/>
            </Style>
        </ControlTheme>
    </UserControl.Resources>

    <ScrollViewer>
        <StackPanel Spacing="16" Margin="16">
            
            <!-- HEADER -->
            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <mi:MaterialIcon Kind="PowerPlug" Width="20" Height="20" 
                                     Foreground="{DynamicResource AccentBlue}"/>
                    <TextBlock Text="{DynamicResource HeaderElectricCircuits}" 
                               FontSize="18" 
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
            
            <!-- GROUPS LIST -->
            <ItemsControl x:Name="CircuitsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:GroupViewModel">
                        
                        <!-- Flattened Group Display -->
                        <StackPanel Margin="0,0,0,16">
                            
                            <!-- GROUP HEADER (RCD) -->
                            <Border Classes="group-header"
                                    Classes.selected="{Binding MainSymbol.IsSelected}"
                                    PointerPressed="OnGroupHeaderPointerPressed"
                                    Background="{DynamicResource PanelBackgroundAlt}"
                                    CornerRadius="8" 
                                    Padding="12,10" 
                                    Margin="0,0,0,4"
                                    BorderBrush="{DynamicResource AccentGreen}"
                                    BorderThickness="3,0,0,0"
                                    ClipToBounds="True">
                                
                                <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                                    <!-- RCD Module Image -->
                                    <Border VerticalAlignment="Center" 
                                            Margin="0,0,12,0" 
                                            Background="{DynamicResource AppBackground}"
                                            CornerRadius="4"
                                            Padding="4"
                                            ClipToBounds="True">
                                        <Image Source="{Binding MainSymbol.Visual}" 
                                               Width="28" Height="50"
                                               Stretch="Uniform"/>
                                    </Border>
                                    
                                    <!-- RCD/SPD Info -->
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <!-- RCD Info (green) -->
                                        <TextBlock Text="{Binding MainSymbol.RcdInfo}" 
                                                   FontSize="12" 
                                                   FontWeight="Bold" 
                                                   Foreground="{DynamicResource AccentGreen}"
                                                   IsVisible="{Binding MainSymbol.RcdInfo, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                        <!-- SPD Info (orange) -->
                                        <TextBlock Text="{Binding MainSymbol.SpdInfo}" 
                                                   FontSize="12" 
                                                   FontWeight="Bold" 
                                                   Foreground="{DynamicResource AccentOrange}"
                                                   IsVisible="{Binding MainSymbol.SpdInfo, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                        <!-- Circuits Count Badge -->
                                        <Border Background="{DynamicResource AppBackground}" 
                                                CornerRadius="10" 
                                                Padding="8,4" 
                                                VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <mi:MaterialIcon Kind="LightningBolt" 
                                                                 Width="12" Height="12" 
                                                                 Foreground="{DynamicResource AccentBlue}"/>
                                                <TextBlock Text="{Binding SubSymbols.Count}" 
                                                           FontSize="11" 
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextMain}"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                    
                                    <!-- Three Dots Menu Button -->
                                    <Button Grid.Column="3" 
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="4"
                                            Margin="4,0,0,0"
                                            Cursor="Hand"
                                            VerticalAlignment="Center">
                                        <Button.Flyout>
                                            <MenuFlyout Placement="BottomEdgeAlignedRight">
                                                <MenuItem Header="{DynamicResource MenuEditGroupModules}" Click="EditGroupModules_Click">
                                                    <MenuItem.Icon>
                                                        <mi:MaterialIcon Kind="Pencil" Width="14" Height="14"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <Separator/>
                                                <MenuItem Header="{DynamicResource MenuUngroup}" Click="UngroupButton_Click" Tag="{Binding GroupId}">
                                                    <MenuItem.Icon>
                                                        <mi:MaterialIcon Kind="FolderRemove" Width="14" Height="14" Foreground="{DynamicResource AccentAmber}"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{DynamicResource MenuDeleteGroup}" Click="DeleteGroup_Click" Tag="{Binding GroupId}">
                                                    <MenuItem.Icon>
                                                        <mi:MaterialIcon Kind="Delete" Width="14" Height="14" Foreground="{DynamicResource AccentRed}"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                            </MenuFlyout>
                                        </Button.Flyout>
                                        <mi:MaterialIcon Kind="DotsVertical" Width="14" Height="14" Foreground="{DynamicResource TextTertiary}"/>
                                    </Button>
                                    
                                    <!-- Expand/Collapse Button -->
                                    <Button Grid.Column="4" 
                                            Command="{Binding ToggleExpandedCommand}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="4"
                                            Cursor="Hand"
                                            VerticalAlignment="Center">
                                        <mi:MaterialIcon Kind="ChevronDown" Width="14" Height="14" Foreground="{DynamicResource TextSecondary}"
                                                         RenderTransform="{Binding IsExpanded, Converter={x:Static converters:BoolToRotateConverter.Instance}}">
                                            <mi:MaterialIcon.Transitions>
                                                <Transitions>
                                                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2"/>
                                                </Transitions>
                                            </mi:MaterialIcon.Transitions>
                                        </mi:MaterialIcon>
                                    </Button>
                                </Grid>
                            </Border>
                            
                            <!-- MCB List (Expandable) -->
                            <Border ClipToBounds="True">
                                <Border.Styles>
                                    <Style Selector="Border.expandable">
                                        <Setter Property="Opacity" Value="1"/>
                                        <Setter Property="MaxHeight" Value="2000"/>
                                        <Setter Property="Transitions">
                                            <Transitions>
                                                <DoubleTransition Property="Opacity" Duration="0:0:0.15"/>
                                                <DoubleTransition Property="MaxHeight" Duration="0:0:0.2"/>
                                            </Transitions>
                                        </Setter>
                                    </Style>
                                    <Style Selector="Border.expandable.collapsed">
                                        <Setter Property="Opacity" Value="0"/>
                                        <Setter Property="MaxHeight" Value="0"/>
                                    </Style>
                                </Border.Styles>
                                
                                <Border Classes="expandable" Classes.collapsed="{Binding !IsExpanded}">
                                    <ItemsControl ItemsSource="{Binding SubSymbols}" Margin="0,0,0,12">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="models:SymbolItem">
                                        
                                                <!-- MCB Row - Compact Tree Item -->
                                                <Border Classes="mcb-row"
                                                        Classes.selected="{Binding IsSelected}"
                                                        PointerPressed="OnCircuitPointerPressed"
                                                        Background="{DynamicResource AppBackground}" 
                                                        Margin="0,1,0,0" 
                                                        Padding="8,6"
                                                        CornerRadius="3">
                                                    
                                                    <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto">
                                                        
                                                        <!-- Tree connector - Modern graphical lines -->
                                                        <Canvas Grid.Column="0" Width="24" Height="40" VerticalAlignment="Stretch" Margin="0,0,4,0">
                                                            <!-- Vertical line (from top, through center) -->
                                                            <Rectangle Canvas.Left="11" Canvas.Top="0" Width="2" Height="20" Fill="{DynamicResource BorderSubtle}"/>
                                                            <!-- Horizontal connector (from center to right) -->
                                                            <Rectangle Canvas.Left="11" Canvas.Top="18" Width="12" Height="2" Fill="{DynamicResource BorderSubtle}"/>
                                                            <!-- Small circle/dot at connection point -->
                                                            <Ellipse Canvas.Left="9" Canvas.Top="16" Width="6" Height="6" Fill="{DynamicResource AccentOrange}"/>
                                                        </Canvas>
                                                        
                                                        <!-- MCB Module Image -->
                                                        <Border Grid.Column="1" 
                                                                VerticalAlignment="Center"
                                                                Margin="0,0,8,0"
                                                                ClipToBounds="True">
                                                            <Image Source="{Binding Visual}" 
                                                                   Width="20" Height="36"
                                                                   Stretch="Uniform"/>
                                                        </Border>
                                                        
                                                        <!-- Module Number -->
                                                        <TextBlock Grid.Column="2" 
                                                                   FontSize="10" 
                                                                   FontWeight="Bold"
                                                                   Foreground="{DynamicResource TextSecondary}"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,0,8,0">
                                                            <TextBlock.Text>
                                                                <MultiBinding StringFormat="#{0}">
                                                                    <Binding Path="ModuleNumber"/>
                                                                </MultiBinding>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                        
                                                        <!-- Protection Badge -->
                                                        <Border Grid.Column="3" Background="{DynamicResource AccentBlue}" CornerRadius="3" Padding="4,2" Margin="0,0,6,0" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding ProtectionType}" FontWeight="Bold" Foreground="White" FontSize="9"/>
                                                        </Border>
                                                        
                                                        <!-- Phase Badge -->
                                                        <Border Grid.Column="4" Background="{DynamicResource AccentOrange}" CornerRadius="3" Padding="4,2" Margin="0,0,6,0" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Phase}" FontWeight="Bold" Foreground="White" FontSize="9"/>
                                                        </Border>
                                                        
                                                        <!-- Circuit Name & Location -->
                                                        <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding CircuitName}" 
                                                                       FontSize="11" 
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource TextMain}"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       MaxWidth="150"/>
                                                            <TextBlock Text="{Binding Location}" 
                                                                       FontSize="10" 
                                                                       Foreground="{DynamicResource TextTertiary}"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       MaxWidth="100"
                                                                       IsVisible="{Binding Location, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                                            <TextBlock FontSize="10" Foreground="{DynamicResource AccentGreenLight}" VerticalAlignment="Center">
                                                                <TextBlock.Text>
                                                                    <MultiBinding StringFormat="{}{0}W">
                                                                        <Binding Path="PowerW"/>
                                                                    </MultiBinding>
                                                                </TextBlock.Text>
                                                            </TextBlock>
                                                        </StackPanel>
                                                        
                                                        <!-- Menu Button -->
                                                        <Button Grid.Column="6" 
                                                                Background="Transparent"
                                                                BorderThickness="0"
                                                                Padding="2"
                                                                Cursor="Hand"
                                                                VerticalAlignment="Center">
                                                            <Button.Flyout>
                                                                <MenuFlyout Placement="BottomEdgeAlignedRight">
                                                                    <MenuItem Header="{DynamicResource MenuEdit}" Click="EditCircuit_Click">
                                                                        <MenuItem.Icon>
                                                                            <mi:MaterialIcon Kind="Pencil" Width="12" Height="12"/>
                                                                        </MenuItem.Icon>
                                                                    </MenuItem>
                                                                    <MenuItem Header="{DynamicResource MenuMoveToGroup}" Click="MoveToGroup_Click">
                                                                        <MenuItem.Icon>
                                                                            <mi:MaterialIcon Kind="FolderMove" Width="12" Height="12" Foreground="{DynamicResource AccentBlue}"/>
                                                                        </MenuItem.Icon>
                                                                    </MenuItem>
                                                                    <Separator/>
                                                                    <MenuItem Header="{DynamicResource MenuDelete}"
                                                                              Command="{Binding #Root.DataContext.ModuleManager.DeleteSymbolCommand}"
                                                                              CommandParameter="{Binding}">
                                                                        <MenuItem.Icon>
                                                                            <mi:MaterialIcon Kind="Delete" Width="12" Height="12" Foreground="{DynamicResource AccentRed}"/>
                                                                        </MenuItem.Icon>
                                                                    </MenuItem>
                                                                </MenuFlyout>
                                                            </Button.Flyout>
                                                            <mi:MaterialIcon Kind="DotsVertical" Width="12" Height="12" Foreground="{DynamicResource TextTertiary}"/>
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                        
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>
                            </Border>
                        </StackPanel>
                        
                        
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            
            <!-- EMPTY STATE -->
            <Border x:Name="EmptyPlaceholder"
                    Background="{DynamicResource PanelBackgroundAlt}" 
                    CornerRadius="12" 
                    Padding="40,48" 
                    IsVisible="True"
                    BorderBrush="{DynamicResource PanelBorder}"
                    BorderThickness="1"
                    BoxShadow="{DynamicResource CardShadow}">
                <StackPanel Spacing="16" HorizontalAlignment="Center">
                    
                    <Border Width="64" Height="64"
                            CornerRadius="32"
                            Background="{DynamicResource PanelBorder}"
                            HorizontalAlignment="Center">
                        <mi:MaterialIcon Kind="FolderOutline" 
                                         Width="32" Height="32" 
                                         Foreground="{DynamicResource TextTertiary}" 
                                         HorizontalAlignment="Center" 
                                         VerticalAlignment="Center"/>
                    </Border>
                    
                    <TextBlock Text="{DynamicResource TextNoCircuitGroups}" 
                               FontSize="16" 
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextMain}"
                               HorizontalAlignment="Center"/>
                    
                    <TextBlock Text="{DynamicResource TextNoCircuitGroupsDesc}"
                               TextAlignment="Center"
                               FontSize="13"
                               Foreground="{DynamicResource TextSecondary}"
                               TextWrapping="Wrap"
                               MaxWidth="300"/>
                    
                </StackPanel>
            </Border>
            
        </StackPanel>
    </ScrollViewer>
</UserControl>
