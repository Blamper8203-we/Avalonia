<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:DINBoard.ViewModels"
             xmlns:mi="using:Material.Icons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
             x:Class="DINBoard.Views.HomeScreenView"
             x:DataType="vm:MainViewModel">

    <Grid Background="{DynamicResource AppBackground}">
        <Grid.ColumnDefinitions>
            <!-- Lewa strona - Logo i Licencja -->
            <ColumnDefinition Width="400"/>
            <!-- Prawa strona - Akcje i Ostatnie projekty -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Tło dla lewej strony (lekko ciemniejsze) -->
        <Border Grid.Column="0" Background="{DynamicResource PanelBackground}" 
                BorderBrush="{DynamicResource PanelBorder}" BorderThickness="0,0,1,0">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20" Margin="40">
                <!-- Logo zastępcze tekstowe, można potem podmienić pod obrazek -->
                <mi:MaterialIcon Kind="DeveloperBoard" Width="100" Height="100" Foreground="{DynamicResource AccentBlue}"/>
                <TextBlock Text="DINBoard" FontSize="48" FontWeight="Bold" Foreground="{DynamicResource TextMain}" HorizontalAlignment="Center"/>
                <TextBlock Text="{DynamicResource HomeVersion}" FontSize="14" Foreground="{DynamicResource TextTertiary}" HorizontalAlignment="Center" Margin="0,-15,0,0"/>

                <!-- Blok Licencji -->
                <Border Background="{DynamicResource PanelBackgroundAlt}" CornerRadius="12" Padding="20" Margin="0,40,0,0" BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1">
                    <StackPanel Spacing="10">
                        <TextBlock Text="{DynamicResource LicenseStatus}" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource TextTertiary}"/>
                        
                        <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding License.IsTrial}">
                            <mi:MaterialIcon Kind="AlertCircleOutline" Width="20" Height="20" Foreground="{DynamicResource AccentOrange}"/>
                            <TextBlock Text="{DynamicResource LicenseTrial}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource AccentOrange}" VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding !License.IsTrial}">
                            <mi:MaterialIcon Kind="CheckCircleOutline" Width="20" Height="20" Foreground="{DynamicResource AccentGreen}"/>
                            <TextBlock Text="{DynamicResource LicenseFull}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource AccentGreen}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock Text="{Binding TrialMessage}" IsVisible="{Binding License.IsTrial}" FontSize="14" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap"/>
                        
                        <StackPanel Orientation="Horizontal" Spacing="4" IsVisible="{Binding !License.IsTrial}">
                            <TextBlock Text="{DynamicResource LicenseRegisteredToPrefix}" FontSize="14" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding License.RegisteredTo}" FontSize="14" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap"/>
                        </StackPanel>

                        <Button Command="{Binding Workspace.ShowActivationDialogCommand}" IsVisible="{Binding License.IsTrial}" Classes="action-btn accent outline" Margin="0,10,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                            <TextBlock Text="{DynamicResource BtnActivateFullVersion}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- Akcje i ostatnie projekty -->
        <ScrollViewer Grid.Column="1" Padding="60">
            <StackPanel Spacing="40">
                
                <TextBlock Text="{DynamicResource HomeWelcome}" FontSize="32" FontWeight="Light" Foreground="{DynamicResource TextMain}"/>
                
                <!-- Główne akcje -->
                <Grid ColumnDefinitions="*,*" Margin="0,10,0,0" Width="600" HorizontalAlignment="Left">
                    <!-- Nowy projekt -->
                    <Button Grid.Column="0" Command="{Binding Workspace.CreateProjectCommand}" 
                            Background="{DynamicResource PanelBackgroundAlt}" BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,0,10,0"
                            HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Left" VerticalContentAlignment="Top">
                        <StackPanel Spacing="15">
                            <mi:MaterialIcon Kind="FileDocumentPlus" Width="40" Height="40" Foreground="{DynamicResource AccentBlue}"/>
                            <TextBlock Text="{DynamicResource HomeActionNewProject}" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextMain}"/>
                            <TextBlock Text="{DynamicResource HomeActionNewProjectDesc}" FontSize="13" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Button>

                    <!-- Otwórz projekt -->
                    <Button Grid.Column="1" Command="{Binding Workspace.OpenProjectCommand}" 
                            Background="{DynamicResource PanelBackgroundAlt}" BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1" CornerRadius="12" Padding="20" Margin="10,0,0,0"
                            HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Left" VerticalContentAlignment="Top">
                        <StackPanel Spacing="15">
                            <mi:MaterialIcon Kind="FolderOpenOutline" Width="40" Height="40" Foreground="{DynamicResource AccentPurple}"/>
                            <TextBlock Text="{DynamicResource HomeActionOpenProject}" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextMain}"/>
                            <TextBlock Text="{DynamicResource HomeActionOpenProjectDesc}" FontSize="13" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Ostatnie projekty -->
                <StackPanel Spacing="15" Margin="0,20,0,0" HorizontalAlignment="Left" Width="600">
                    <TextBlock Text="{DynamicResource HomeRecentProjects}" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextMain}"/>
                    
                    <Border Background="{DynamicResource PanelBackgroundAlt}" BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1" CornerRadius="8" Padding="5">
                        <ItemsControl ItemsSource="{Binding RecentProjects}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding $parent[UserControl].((vm:MainViewModel)DataContext).Workspace.OpenRecentProjectCommand}" CommandParameter="{Binding}" 
                                            Background="Transparent" BorderThickness="0" CornerRadius="4" Padding="15,10" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left">
                                        <Grid ColumnDefinitions="Auto,*">
                                            <mi:MaterialIcon Kind="FileOutline" Width="20" Height="20" Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding}" Margin="15,0,0,0" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="2"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </Border>
                    
                    <TextBlock Text="{DynamicResource HomeNoRecentProjects}" IsVisible="{Binding !HasRecentProjects}" FontSize="13" Foreground="{DynamicResource TextTertiary}" FontStyle="Italic"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
