<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:DINBoard.ViewModels"
             xmlns:views="using:DINBoard.Views"
             xmlns:mi="using:Material.Icons.Avalonia"
             xmlns:services="using:DINBoard.Services"
             x:Class="DINBoard.Views.MainRightPanelView"
             x:DataType="vm:MainViewModel"
             mc:Ignorable="d"
             d:DesignWidth="320"
             d:DesignHeight="700">
    <Border x:Name="RightPanel"
            Background="{DynamicResource PanelBackground}"
            BorderThickness="1,0,0,0"
            BorderBrush="{DynamicResource PanelBorder}">
        <Grid Margin="12" RowDefinitions="Auto,Auto,*">
            <TextBlock Text="{DynamicResource HeaderRightPanelProperties}"
                       Margin="4,2,4,12"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextMain}"/>
            <Border Grid.Row="1" Height="1" Background="{DynamicResource PanelBorder}" Opacity="0.8"/>
            <TabControl x:Name="RightTabControl"
                        Grid.Row="2"
                        Margin="0,14,0,0"
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0">
                <TabControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" Margin="0,0,0,10"/>
                    </ItemsPanelTemplate>
                </TabControl.ItemsPanel>
                <TabControl.Styles>
                    <Style Selector="TabItem">
                        <Setter Property="Padding" Value="14,8"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Margin" Value="0,0,8,8"/>
                        <Setter Property="ZIndex" Value="1"/>
                        <Setter Property="Background" Value="{DynamicResource PanelBackgroundAlt}"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                        <Setter Property="Tag" Value="{DynamicResource TextSecondary}"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="CornerRadius" Value="8"/>
                        <Setter Property="MinWidth" Value="56"/>
                        <Setter Property="MinHeight" Value="36"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="Transitions">
                            <Transitions>
                                <BrushTransition Property="Background" Duration="0:0:0.12"/>
                                <BrushTransition Property="BorderBrush" Duration="0:0:0.12"/>
                                <BrushTransition Property="Foreground" Duration="0:0:0.12"/>
                            </Transitions>
                        </Setter>
                    </Style>
                    <Style Selector="TabItem:pointerover">
                        <Setter Property="Background" Value="{DynamicResource PanelBackgroundAlt}"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
                        <Setter Property="Tag" Value="{DynamicResource TextMain}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource PanelBorder}"/>
                    </Style>
                    <Style Selector="TabItem:selected">
                        <Setter Property="Background" Value="{DynamicResource PanelBackgroundAlt}"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
                        <Setter Property="Tag" Value="{DynamicResource AccentBlue}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
                    </Style>
                </TabControl.Styles>

                <!-- TAB 1: Konfiguracja -->
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <mi:MaterialIcon Kind="Cog"
                                             Width="16"
                                             Height="16"
                                             Foreground="{Binding Tag, RelativeSource={RelativeSource AncestorType=TabItem}}"/>
                            <TextBlock Text="{DynamicResource TabConfiguration}"
                                       TextWrapping="NoWrap"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Border Margin="0,10,0,0" Background="Transparent">
                        <views:PowerConfigPanel/>
                    </Border>
                </TabItem>

                <!-- TAB 2: Bilans -->
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <mi:MaterialIcon Kind="ChartBar"
                                             Width="16"
                                             Height="16"
                                             Foreground="{Binding Tag, RelativeSource={RelativeSource AncestorType=TabItem}}"/>
                            <TextBlock Text="{DynamicResource TabBalance}"
                                       TextWrapping="NoWrap"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Border Margin="0,10,0,0" Background="Transparent">
                        <views:PowerBalancePanel x:Name="PnlPowerBalance"/>
                    </Border>
                </TabItem>

                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <mi:MaterialIcon Kind="InformationOutline"
                                             Width="16"
                                             Height="16"
                                             Foreground="{Binding Tag, RelativeSource={RelativeSource AncestorType=TabItem}}"/>
                            <TextBlock Text="{DynamicResource TabValidation}"
                                       TextWrapping="NoWrap"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Border Margin="0,10,0,0" Background="Transparent">
                        <ScrollViewer>
                            <StackPanel Spacing="8" Margin="8">
                                <TextBlock Classes="section-header" Text="{DynamicResource ValidationResults}"/>
                                <Border Classes="card">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="{Binding Validation.ValidationSummary}" FontWeight="SemiBold"/>
                                        <StackPanel Orientation="Horizontal" Spacing="16">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <mi:MaterialIcon Kind="CloseCircleOutline" Width="14" Height="14" Foreground="{DynamicResource AccentRed}"/>
                                                <TextBlock Text="{DynamicResource ValidationErrorsPrefix}" Classes="secondary"/>
                                                <TextBlock Text="{Binding Validation.ValidationErrorCount}" Classes="secondary"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <mi:MaterialIcon Kind="AlertCircleOutline" Width="14" Height="14" Foreground="{DynamicResource AccentOrange}"/>
                                                <TextBlock Text="{DynamicResource ValidationWarningsPrefix}" Classes="secondary"/>
                                                <TextBlock Text="{Binding Validation.ValidationWarningCount}" Classes="secondary"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <Border Classes="card">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="{DynamicResource ValidationMessages}" FontWeight="SemiBold"/>
                                        <ItemsControl ItemsSource="{Binding Validation.ValidationMessages}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Spacing="8"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="services:ValidationMessage">
                                                    <Border Padding="6" Background="{DynamicResource PanelBackgroundAlt}" CornerRadius="4">
                                                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="6">
                                                            <mi:MaterialIcon Width="12" Height="12" Kind="AlertCircleOutline" Foreground="{DynamicResource AccentOrange}"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding Message}" FontWeight="Medium" FontSize="11" TextWrapping="Wrap"/>
                                                            <TextBlock Grid.Column="1" Grid.Row="1" Text="{Binding Details}" Classes="secondary" FontSize="9" TextWrapping="Wrap"/>
                                                            <StackPanel Grid.Column="1" Grid.Row="2" Orientation="Horizontal" Spacing="4">
                                                                <TextBlock Classes="tertiary" FontSize="9" Text="{Binding Severity}"/>
                                                                <TextBlock Classes="tertiary" FontSize="9" Text="·"/>
                                                                <TextBlock Classes="tertiary" FontSize="9" Text="{DynamicResource ValidationCodePrefix}"/>
                                                                <TextBlock Classes="tertiary" FontSize="9" Text=":"/>
                                                                <TextBlock Classes="tertiary" FontSize="9" Text="{Binding Code}"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <TextBlock Text="{DynamicResource ValidationNoMessages}" IsVisible="{Binding Validation.HasValidationMessages, Converter={StaticResource InverseBoolConverter}}" Classes="secondary"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </TabItem>

                <TabItem x:Name="CircuitEditTab">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <mi:MaterialIcon Kind="Pencil"
                                             Width="16"
                                             Height="16"
                                             Foreground="{Binding Tag, RelativeSource={RelativeSource AncestorType=TabItem}}"/>
                            <TextBlock Text="{DynamicResource TabCircuitEdit}"
                                       TextWrapping="NoWrap"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Border Margin="0,10,0,0" Background="Transparent">
                        <views:CircuitEditPanelView x:Name="CircuitEditPanel"/>
                    </Border>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</UserControl>
