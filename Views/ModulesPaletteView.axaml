<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:mi="using:Material.Icons.Avalonia"
             xmlns:converters="using:DINBoard.Converters"
             xmlns:local="clr-namespace:DINBoard.Views"
             xmlns:vm="using:DINBoard.ViewModels"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             x:Class="DINBoard.Views.ModulesPaletteView"
             x:Name="PaletteRoot"
             x:DataType="vm:MainViewModel"
             mc:Ignorable="d" d:DesignWidth="250" d:DesignHeight="500">
             
    <UserControl.Resources>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
    </UserControl.Resources>
    
    <Border Background="{DynamicResource PanelBackground}" BorderThickness="0,0,1,0" BorderBrush="{DynamicResource PanelBorder}">
        <Grid RowDefinitions="Auto,Auto,*">
            <TextBlock Text="{DynamicResource HeaderModules}" Classes="section-header" Margin="8,6"/>


            
            <Grid Grid.Row="2">
                <TabControl Margin="0" Padding="0"
                            IsVisible="{Binding #PaletteRoot.IsModulesEnabled}"
                            ItemsSource="{Binding #PaletteRoot.Categories}">
                    <TabControl.Styles>
                        <Style Selector="TabItem">
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="Padding" Value="6,4"/>
                        </Style>
                    </TabControl.Styles>

                    <TabControl.ItemTemplate>
                        <DataTemplate x:DataType="local:ModulesPaletteView+ModuleCategory">
                            <TextBlock Text="{Binding Name}">
                                <TextBlock.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="{DynamicResource MenuDeleteTab}" Click="DeleteCategory_Click"/>
                                    </ContextMenu>
                                </TextBlock.ContextMenu>
                            </TextBlock>
                        </DataTemplate>
                    </TabControl.ItemTemplate>

                    <TabControl.ContentTemplate>
                        <DataTemplate x:DataType="local:ModulesPaletteView+ModuleCategory" x:CompileBindings="False">
                            <ScrollViewer>
                                <ItemsControl ItemsSource="{Binding Items}">
                                    <ItemsControl.ItemTemplate>
                                         <DataTemplate x:DataType="local:ModulesPaletteView+PaletteItem">
                                            <Border Background="{DynamicResource PanelBackgroundAlt}" Margin="4,2" Padding="6" CornerRadius="4"
                                                    BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1"
                                                    PointerPressed="OnPointerPressed"
                                                    ToolTip.Tip="{Binding Description}">
                                                <Border.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="{DynamicResource MenuDelete}" Click="DeleteModule_Click"/>
                                                    </ContextMenu>
                                                </Border.ContextMenu>
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <mi:MaterialIcon Kind="{Binding IconKind}" Width="{Binding DataContext.Schematic.IconSize, RelativeSource={RelativeSource AncestorType=local:ModulesPaletteView}}" Height="{Binding DataContext.Schematic.IconSize, RelativeSource={RelativeSource AncestorType=local:ModulesPaletteView}}" IsVisible="{Binding !HasVisual}"/>
                                                    <Image Source="{Binding Visual}" Width="{Binding DataContext.Schematic.IconSize, RelativeSource={RelativeSource AncestorType=local:ModulesPaletteView}}" Height="{Binding DataContext.Schematic.IconSize, RelativeSource={RelativeSource AncestorType=local:ModulesPaletteView}}" IsVisible="{Binding HasVisual}"/>
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}" FontWeight="Medium" FontSize="11"/>
                                                        <TextBlock Text="{Binding Description}" FontSize="9" Classes="secondary"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DataTemplate>
                    </TabControl.ContentTemplate>
                </TabControl>

                <!-- Validation Overlay - Blocks interaction -->
                <Border Background="{DynamicResource OverlayBackground}" 
                        IsVisible="{Binding #PaletteRoot.IsModulesEnabled, Converter={StaticResource InverseBoolConverter}}"
                        IsHitTestVisible="True"
                        ZIndex="100"
                        VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                        CornerRadius="4">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="6" Opacity="0.7">
                        <mi:MaterialIcon Kind="AlertCircleOutline" Width="24" Height="24" Foreground="{DynamicResource AccentRed}"/>
                        <TextBlock Text="{DynamicResource TextDinRailRequired}" FontWeight="Medium" FontSize="11" Foreground="{DynamicResource TextMain}" TextAlignment="Center"/>
                        <TextBlock Text="{DynamicResource TextDinRailRequiredDesc}" FontSize="10" Foreground="{DynamicResource TextSecondary}" TextAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</UserControl>
