<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:DINBoard.ViewModels"
             xmlns:mi="using:Material.Icons.Avalonia"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="450"
             x:Class="DINBoard.Views.PdfPreviewView"
             x:DataType="vm:ExportViewModel">

    <Grid RowDefinitions="Auto,Auto,*,Auto">
        <Border Grid.Row="0"
                Background="{DynamicResource ToolbarBackground}"
                BorderBrush="{DynamicResource PanelBorder}"
                BorderThickness="0,0,0,1"
                Padding="12,10">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Spacing="4">
                    <TextBlock Text="Podglad PDF"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextMain}"/>
                    <TextBlock Text="{Binding PdfPreviewStatusMessage}"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondary}"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Command="{Binding RefreshPdfPreviewCommand}"
                        Padding="12,6"
                        Background="{DynamicResource AccentBlue}"
                        Foreground="White">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <mi:MaterialIcon Kind="Refresh" Width="16" Height="16"/>
                        <TextBlock Text="Odswiez" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                IsVisible="{Binding IsPdfPreviewInProgress}"
                Background="{DynamicResource PanelBackgroundAlt}"
                BorderBrush="{DynamicResource PanelBorder}"
                BorderThickness="0,0,0,1"
                Padding="12,8">
            <Grid RowDefinitions="Auto,Auto"
                  ColumnDefinitions="*,Auto">
                <ProgressBar Grid.Row="0"
                             Grid.ColumnSpan="2"
                             Minimum="0"
                             Maximum="100"
                             Value="{Binding PdfPreviewProgressPercent}"
                             Height="8"/>
                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Margin="0,6,0,0"
                           Text="{Binding PdfPreviewLongOperationReason}"
                           FontSize="11"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource TextSecondary}"/>
                <TextBlock Grid.Row="1"
                           Grid.Column="1"
                           Margin="12,6,0,0"
                           Text="{Binding PdfPreviewProgressPercent, StringFormat='{}{0}%'}"
                           FontSize="11"
                           Foreground="{DynamicResource TextSecondary}"/>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Margin="12"
                Background="#FFFFFF"
                BorderBrush="{DynamicResource PanelBorder}"
                BorderThickness="1"
                CornerRadius="8">
            <Grid Background="#FFFFFF">
                <TextBlock Text="Kliknij 'Odswiez', aby wygenerowac podglad PDF."
                           IsVisible="{Binding IsPdfPreviewEmpty}"
                           FontSize="13"
                           Foreground="{DynamicResource TextSecondary}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                <ScrollViewer IsVisible="{Binding HasPdfPreview}"
                              Background="#FFFFFF"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto">
                    <Image Source="{Binding CurrentPdfPreviewImage}"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Top"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Background="{DynamicResource ToolbarBackground}"
                BorderBrush="{DynamicResource PanelBorder}"
                BorderThickness="0,1,0,0"
                Padding="12,8">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                <Button Command="{Binding ShowPreviousPdfPreviewPageCommand}"
                        IsEnabled="{Binding CanGoToPreviousPdfPreviewPage}"
                        Padding="8,5"
                        Margin="0,0,6,0">
                    <mi:MaterialIcon Kind="ChevronLeft" Width="16" Height="16"/>
                </Button>

                <Button Grid.Column="1"
                        Command="{Binding ShowNextPdfPreviewPageCommand}"
                        IsEnabled="{Binding CanGoToNextPdfPreviewPage}"
                        Padding="8,5">
                    <mi:MaterialIcon Kind="ChevronRight" Width="16" Height="16"/>
                </Button>

                <TextBlock Grid.Column="3"
                           Text="{Binding PdfPreviewPageLabel}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondary}"
                           FontSize="12"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
