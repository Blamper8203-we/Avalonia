<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:local="clr-namespace:DINBoard.Views"
             xmlns:vm="clr-namespace:DINBoard.ViewModels"
             x:Class="DINBoard.Views.PowerBalancePanel"
             x:DataType="vm:MainViewModel"
             mc:Ignorable="d" d:DesignWidth="280" d:DesignHeight="500">

    <UserControl.Styles>
        <Style Selector="TextBlock.phase-value">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBlock.phase-power">
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Foreground" Value="{DynamicResource TextTertiary}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Border.phase-bar">
            <Setter Property="Height" Value="6"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Margin" Value="0,3,0,0"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer>
        <StackPanel Spacing="8" Margin="8">

            <TextBlock Classes="section-header" Text="{DynamicResource HeaderPowerBalance}"/>

            <!-- Power Summary Card -->
            <Border Classes="card">
                <StackPanel Spacing="8">
                    <!-- Installed Power -->
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <mi:MaterialIcon Kind="FlashOutline" Width="14" Height="14" Foreground="{DynamicResource AccentBlue}"/>
                            <TextBlock Text="{DynamicResource LabelInstalledPower}" VerticalAlignment="Center" Classes="secondary" FontSize="11"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" FontWeight="Bold" FontSize="12">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0:N2} kW">
                                    <Binding Path="PowerBalance.TotalInstalledPowerW" Converter="{x:Static local:PowerBalancePanel.WattsToKwConverter}"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </Grid>
                    
                    <Border Height="1" Background="{DynamicResource PanelBorder}"/>
                    
                    <!-- Calculated Power -->
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <mi:MaterialIcon Kind="Calculator" Width="14" Height="14" Foreground="{DynamicResource AccentGreen}"/>
                            <TextBlock Text="{DynamicResource LabelCalculatedPower}" VerticalAlignment="Center" Classes="secondary" FontSize="11"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" FontWeight="Bold" FontSize="12">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0:N2} kW">
                                    <Binding Path="PowerBalance.CalculatedPowerW" Converter="{x:Static local:PowerBalancePanel.WattsToKwConverter}"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </Grid>

                    <Border Height="1" Background="{DynamicResource PanelBorder}"/>

                    <!-- Simultaneity Factor -->
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <mi:MaterialIcon Kind="ChartTimelineVariant" Width="14" Height="14" Foreground="{DynamicResource AccentOrange}"/>
                            <TextBlock Text="{DynamicResource LabelSimultaneityFactor}" VerticalAlignment="Center" Classes="secondary" FontSize="11"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="{Binding PowerBalance.SimultaneityFactor, StringFormat={}{0:N1}}" FontWeight="Bold" FontSize="12"/>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- Phase Balance -->
            <TextBlock Classes="section-header" Text="{DynamicResource HeaderPhaseBalance}"/>
            
            <Border Classes="card">
                <StackPanel Spacing="8">
                    <!-- L1 -->
                    <StackPanel ToolTip.Tip="{DynamicResource TooltipPhaseLoadL1}">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Border Background="{DynamicResource AccentBlue}" CornerRadius="3" Padding="6,2" HorizontalAlignment="Left">
                                <TextBlock Text="L1" FontWeight="Bold" Foreground="White" FontSize="10"/>
                            </Border>
                            <TextBlock Grid.Column="2" Text="{Binding PowerBalance.L1CurrentA, StringFormat={}{0:N1} A}" Classes="phase-value"/>
                        </Grid>
                        <Grid Margin="0,4,0,0">
                            <Border Background="{DynamicResource PanelBorder}" Classes="phase-bar"/>
                            <Border Background="{DynamicResource AccentBlue}" Classes="phase-bar" HorizontalAlignment="Left"
                                    Width="{Binding PowerBalance.L1CurrentA, Converter={x:Static local:PowerBalancePanel.CurrentToWidthConverter}}"/>
                        </Grid>
                        <TextBlock Text="{Binding PowerBalance.L1PowerW, StringFormat={}{0:N0} W}" Classes="phase-power"/>
                    </StackPanel>
                    
                    <!-- L2 -->
                    <StackPanel ToolTip.Tip="{DynamicResource TooltipPhaseLoadL2}">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Border Background="{DynamicResource AccentOrange}" CornerRadius="3" Padding="6,2" HorizontalAlignment="Left">
                                <TextBlock Text="L2" FontWeight="Bold" Foreground="{DynamicResource TextMain}" FontSize="10"/>
                            </Border>
                            <TextBlock Grid.Column="2" Text="{Binding PowerBalance.L2CurrentA, StringFormat={}{0:N1} A}" Classes="phase-value"/>
                        </Grid>
                        <Grid Margin="0,4,0,0">
                            <Border Background="{DynamicResource PanelBorder}" Classes="phase-bar"/>
                            <Border Background="{DynamicResource AccentOrange}" Classes="phase-bar" HorizontalAlignment="Left"
                                    Width="{Binding PowerBalance.L2CurrentA, Converter={x:Static local:PowerBalancePanel.CurrentToWidthConverter}}"/>
                        </Grid>
                        <TextBlock Text="{Binding PowerBalance.L2PowerW, StringFormat={}{0:N0} W}" Classes="phase-power"/>
                    </StackPanel>
                    
                    <!-- L3 -->
                    <StackPanel ToolTip.Tip="{DynamicResource TooltipPhaseLoadL3}">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Border Background="{DynamicResource AccentRed}" CornerRadius="3" Padding="6,2" HorizontalAlignment="Left">
                                <TextBlock Text="L3" FontWeight="Bold" Foreground="White" FontSize="10"/>
                            </Border>
                            <TextBlock Grid.Column="2" Text="{Binding PowerBalance.L3CurrentA, StringFormat={}{0:N1} A}" Classes="phase-value"/>
                        </Grid>
                        <Grid Margin="0,4,0,0">
                            <Border Background="{DynamicResource PanelBorder}" Classes="phase-bar"/>
                            <Border Background="{DynamicResource AccentRed}" Classes="phase-bar" HorizontalAlignment="Left"
                                    Width="{Binding PowerBalance.L3CurrentA, Converter={x:Static local:PowerBalancePanel.CurrentToWidthConverter}}"/>
                        </Grid>
                        <TextBlock Text="{Binding PowerBalance.L3PowerW, StringFormat={}{0:N0} W}" Classes="phase-power"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            
            <!-- Asymmetry Info -->
            <Border Classes="card" Padding="8" ToolTip.Tip="{DynamicResource TooltipAsymmetry}">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <mi:MaterialIcon Kind="ScaleBalance" Width="14" Height="14" Foreground="{DynamicResource TextTertiary}"/>
                    <TextBlock Grid.Column="1" Text="{DynamicResource LabelPhaseAsymmetry}" VerticalAlignment="Center" Margin="6,0,0,0" Classes="secondary" FontSize="11"/>
                    <TextBlock Grid.Column="2" Text="{Binding PowerBalance.PhaseImbalancePercent, StringFormat={}{0:N1} %}" 
                               FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Status -->
            <Border x:Name="StatusBorder" Padding="8,5" CornerRadius="4">
                <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                    <mi:MaterialIcon x:Name="StatusIcon" Width="14" Height="14"/>
                    <TextBlock x:Name="StatusText" FontWeight="Medium" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Auto-Balance Section -->
            <TextBlock Classes="section-header" Text="{DynamicResource HeaderAutoBalance}" Margin="0,8,0,0"/>

            <Border Classes="card">
                <StackPanel Spacing="8">
                    <Button Command="{Binding Schematic.AutoBalancePhasesCommand}"
                            IsEnabled="{Binding !Schematic.IsBalancing}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Padding="8,6"
                            Background="{DynamicResource AccentBlue}"
                            CornerRadius="4"
                            x:Name="BtnAutoBalance">
                        <Panel>
                            <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center"
                                        IsVisible="{Binding !Schematic.IsBalancing}">
                                <TextBlock Text="⚡" FontSize="11" VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource BtnAutoBalance}" FontWeight="Bold" FontSize="11" Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center"
                                        IsVisible="{Binding Schematic.IsBalancing}">
                                <mi:MaterialIcon Kind="Loading" Width="14" Height="14" Foreground="White" VerticalAlignment="Center">
                                    <mi:MaterialIcon.Styles>
                                        <Style Selector="mi|MaterialIcon">
                                            <Style.Animations>
                                                <Animation Duration="0:0:1" IterationCount="Infinite">
                                                    <KeyFrame Cue="0%">
                                                        <Setter Property="RotateTransform.Angle" Value="0"/>
                                                    </KeyFrame>
                                                    <KeyFrame Cue="100%">
                                                        <Setter Property="RotateTransform.Angle" Value="360"/>
                                                    </KeyFrame>
                                                </Animation>
                                            </Style.Animations>
                                        </Style>
                                    </mi:MaterialIcon.Styles>
                                </mi:MaterialIcon>
                                <TextBlock Text="{DynamicResource TextBalancing}" FontWeight="Bold" FontSize="11" Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Panel>
                    </Button>

                    <Button Content="{DynamicResource BtnUndoBalance}"
                            Command="{Binding Schematic.UndoLastBalanceCommand}"
                            IsEnabled="{Binding Schematic.CanUndoLastBalance}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Padding="6,4"
                            FontSize="10"
                            CornerRadius="4"
                            x:Name="BtnUndoBalance"/>
                </StackPanel>
            </Border>
            
        </StackPanel>
    </ScrollViewer>
</UserControl>
